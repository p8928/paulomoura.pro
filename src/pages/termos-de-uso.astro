---

<BaseLayout title="Termos de Uso" description="Termos aplicáveis ao acesso, navegação, conteúdo, candidatura e uso do site Paulo Moura." canonicalPath="/termos-de-uso" showChrome={false}>
  <script>
    import '@scripts/lenis';
  </script>

  <HeroNavigation client:load />
