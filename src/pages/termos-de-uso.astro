    kicker="Termos"
    title="Termos de Uso."
    summary="Regras de acesso, navegação, uso do conteúdo, candidatura, ferramentas de terceiros e limitações do site."
    updatedAt="04/06/2026"
    sections={sections}
  />
  <SiteFooter />
</BaseLayout>
