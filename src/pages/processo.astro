---
import BaseLayout from '@layouts/BaseLayout.astro';
---

<BaseLayout title="Processo">
  <section class="mx-auto max-w-6xl px-5 pb-20 pt-32 lg:px-8">
    <p class="text-sm uppercase tracking-[0.22em] text-wine">Processo</p>
    <h1 class="mt-5 font-serif text-6xl leading-tight">Da leitura do negocio a presenca digital.</h1>
    <p class="mt-6 max-w-3xl text-lg leading-8 text-muted">
      O processo parte de diagnostico e observacao antes de transformar identidade, linguagem, site e mecanismos de descoberta.
    </p>
  </section>
</BaseLayout>
