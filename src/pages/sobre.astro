---
import BaseLayout from '@layouts/BaseLayout.astro';
---

<BaseLayout title="Sobre Paulo Moura">
  <section class="mx-auto max-w-6xl px-5 pb-20 pt-32 lg:px-8">
    <p class="text-sm uppercase tracking-[0.22em] text-wine">Autoria</p>
    <h1 class="mt-5 font-serif text-6xl leading-tight">Paulo Moura</h1>
    <p class="mt-6 max-w-3xl text-lg leading-8 text-muted">
      Branding, comunicacao digital e arquitetura de presenca para empresas que precisam tornar visivel a qualidade que ja possuem.
    </p>
  </section>
</BaseLayout>
