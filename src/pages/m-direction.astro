---
import BaseLayout from '@layouts/BaseLayout.astro';
---

<BaseLayout title="M-Direction">
  <section class="mx-auto max-w-6xl px-5 pb-20 pt-32 lg:px-8">
    <p class="text-sm uppercase tracking-[0.22em] text-wine">Continuidade</p>
    <h1 class="mt-5 font-serif text-6xl leading-tight">M-Direction</h1>
    <p class="mt-6 max-w-3xl text-lg leading-8 text-muted">
      Direcao continua para comunicacao, conteudo, semiotica, concorrencia e fortalecimento editorial da marca.
    </p>
  </section>
</BaseLayout>
