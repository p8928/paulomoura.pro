---
import BadgeStandardPage from '@components/sections/badges/BadgeStandardPage.astro';
import HeroNavigation from '@components/navigation/HeroNavigation.svelte';
import SiteFooter from '@components/site/SiteFooter.astro';
import { badgeStandardBySlug } from '@data/badgeStandards';
import { badgeStandardSchema, schemaIdentity } from '@data/schema';
import BaseLayout from '@layouts/BaseLayout.astro';

const standard = badgeStandardBySlug['moura-star'];
const standardUrl = schemaIdentity.baseUrl + '/moura-star/';
const standardSchema = badgeStandardSchema({ standard, url: standardUrl });
---

<BaseLayout
  title="MOURA | Star"
  description={standard.description}
  canonicalPath="/moura-star"
  schemaPageType="WebPage"
  schemaMainEntity={{ '@id': standardUrl + '#standard' }}
  structuredData={standardSchema}
  showChrome={false}
>
  <script>
    import '@scripts/lenis';
  </script>

  <HeroNavigation client:load />
  <BadgeStandardPage standard={standard} />
  <SiteFooter />
</BaseLayout>
