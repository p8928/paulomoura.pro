---
import DiagnosticConfigurator from '@components/diagnostic/DiagnosticConfigurator.svelte';
import BaseLayout from '@layouts/BaseLayout.astro';
---

<BaseLayout title="Diagnostico">
  <section class="mx-auto max-w-5xl px-5 pb-20 pt-32 lg:px-8">
    <p class="text-sm uppercase tracking-[0.22em] text-wine">Entrada seletiva</p>
    <h1 class="mt-5 font-serif text-6xl leading-tight">Diagnostico inicial</h1>
    <p class="mt-6 max-w-3xl text-lg leading-8 text-muted">
      Um fluxo breve para organizar contexto, escopo e momento antes de uma conversa.
    </p>
    <div class="mt-10">
      <DiagnosticConfigurator client:load />
    </div>
  </section>
</BaseLayout>
