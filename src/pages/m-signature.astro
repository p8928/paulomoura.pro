---
import HeroNavigation from '@components/navigation/HeroNavigation.svelte';
import SiteFooter from '@components/site/SiteFooter.astro';
import { signatureSectors } from '@data/signatureSectors';
import BaseLayout from '@layouts/BaseLayout.astro';
import { itemListSchema, schemaIdentity, serviceSchema } from '@data/schema';

const scopeItems = [
  {
    title: 'Leitura da operação e do negócio',
    copy:
      'Antes de projetar qualquer interface, o trabalho observa como a empresa funciona, como atende, o que promete, o que entrega e quais valores aparecem na prática. Essa leitura orienta as decisões de linguagem, estrutura e prioridade.',
  },
  {
    title: 'Direção de marca e linguagem',
    copy:
      'A comunicação é organizada para revelar substância real: tom, vocabulário, hierarquia de mensagens, argumentos comerciais, diferenciais e critérios de confiança deixam de depender de frases genéricas.',
  },
  {
    title: 'Site, experiência e estrutura técnica',
    copy:
      'A presença principal é construída em uma base moderna, rápida e segura, com arquitetura de informação, experiência, performance, SEO, AEO, GEO e dados estruturados tratados como partes do mesmo sistema.',
  },
  {
    title: 'Presença local e sinais públicos',
    copy:
      'Google Business Profile, consistência de dados públicos, pontos de reputação, perfis e sinais externos são revisados para que clientes, motores de busca e sistemas de IA encontrem uma entidade coerente.',
  },
];

const fitItems = [
  'Empresas e profissionais com ticket alto e entrega acima da média.',
  'Negócios premium ou luxury cuja presença digital não comunica o valor real da operação.',
  'Marcas que dependem demais de mídia paga para adquirir clientes e desejam construir ativos próprios.',
  'Operações que sabem que um projeto comum não resolve um problema de posicionamento, linguagem, busca e confiança.',
];

const nonFitItems = [
  'Negócios orientados apenas por preço.',
  'Empresas que procuram uma solução rápida, genérica ou de baixo orçamento.',
  'Projetos que desejam apenas uma nova aparência visual sem rever mensagem, estrutura e sinais digitais.',
];

const clarityModules = [
  {
    label: 'Problema',
    copy: 'Qualidade real, presença digital genérica e sinais públicos insuficientes para sustentar confiança antes do contato.',
  },
  {
    label: 'Intervenção',
    copy: 'Leitura do negócio, direção de linguagem, site, estrutura técnica, SEO, AEO, GEO e presença local sob o mesmo critério.',
  },
  {
    label: 'Resultado esperado',
    copy: 'Uma presença mais clara, confiável e compreensível para clientes, motores de busca e sistemas de IA.',
  },
];

const processSteps = [
  {
    label: '01',
    title: 'Candidatura e diagnóstico',
    copy:
      'A entrada começa pela candidatura. O diagnóstico avalia o momento do negócio, a qualidade da entrega, os pontos fracos da presença atual e a aderência ao método Brand-Driven.',
  },
  {
    label: '02',
    title: 'Leitura e direção',
    copy:
      'O projeto organiza o que precisa ser comunicado antes de decidir como será apresentado. Essa etapa define narrativa, escopo, prioridades e estrutura da presença digital.',
  },
  {
    label: '03',
    title: 'Construção da presença',
    copy:
      'Site, conteúdo, experiência, dados estruturados, sinais de entidade e presença local são implementados com foco em clareza, confiança, performance e legibilidade para busca e IA.',
  },
  {
    label: '04',
    title: 'Entrega e continuidade possível',
    copy:
      'Ao fim dos 90 dias, a empresa recebe a base construída. Se fizer sentido manter direção estratégica, a continuidade acontece por ',
    link: {
      href: '/m-direction',
      label: 'M-Direction',
    },
    suffix: '.',
  },
];


const signatureUrl = schemaIdentity.baseUrl + '/m-signature/';
const signatureServiceSchema = serviceSchema({
  id: signatureUrl + '#service',
  name: 'M-Signature',
  description: 'Implementação Brand-Driven para empresas premium que precisam transformar qualidade real em presença digital clara, confiável e legível para clientes, busca e IA.',
  serviceType: 'Implementação Brand-Driven de presença digital',
  url: signatureUrl,
  audience: 'Empresas e profissionais premium ou luxury',
});
const signatureScopeSchema = itemListSchema({
  id: signatureUrl + '#scope',
  name: 'Escopo integrado do M-Signature',
  items: scopeItems.map((item) => ({ name: item.title, description: item.copy })),
});

const technicalLayers = [
  ['Performance', 'carregamento rápido, arquitetura leve e menor dependência de camadas visuais limitadas'],
  ['Semântica', 'hierarquia de conteúdo, marcação clara e organização legível por sistemas'],
  ['Dados estruturados', 'schema, entidade, contexto editorial e sinais de confiança tratados no código'],
  ['Infraestrutura', 'base moderna com Astro, Svelte e distribuição adequada ao projeto'],
  ['Experiência', 'navegação, leitura e prioridade de informação conduzidas pelo valor real da empresa'],
];
---

<BaseLayout
  title="MOURA | M-Signature"
  description="M-Signature constrói presença digital a partir do que a empresa realmente sustenta, com clareza para pessoas, precisão para motores de busca e legibilidade para sistemas de IA."
  canonicalPath="/m-signature"
  schemaPageType="WebPage"
  schemaMainEntity={{ '@id': signatureUrl + '#service' }}
  structuredData={[signatureServiceSchema, signatureScopeSchema]}
  showChrome={false}
>
  <script>
    import '@scripts/lenis';
  </script>

  <HeroNavigation client:load />

  <main class="signature-page">
    <section class="signature-hero" data-nav-surface="dark" aria-labelledby="signature-title">
      <div class="signature-shell signature-hero-grid">
        <div class="signature-hero-copy">
          <p class="signature-kicker">M-Signature</p>
          <h1 id="signature-title">Presença digital com assinatura, substância e estrutura.</h1>
        </div>

        <aside class="signature-hero-aside" aria-label="Resumo do M-Signature">
          <p>
            M-Signature é a implementação Brand-Driven para empresas e profissionais que entregam qualidade acima da média, mas ainda são apresentados no digital de forma insuficiente, genérica ou incompatível com seu valor real.
          </p>
          <a class="moura-button moura-button-outline-light" href="/candidatura">Iniciar candidatura</a>
        </aside>
      </div>

      <aside class="signature-hero-system" aria-label="Coordenadas do serviço">
        <p>90 dias / Projeto fechado</p>
        <span>Leitura do negócio</span>
        <span>SEO, AEO e GEO</span>
        <span>Candidatura avaliada</span>
      </aside>
    </section>

    <section class="signature-thesis" data-nav-surface="light" aria-labelledby="signature-thesis-title">
      <div class="signature-shell signature-thesis-layout">
        <header class="signature-section-head signature-thesis-head">
          <p class="signature-kicker signature-kicker-dark">Antes do escopo</p>
          <span>01 / Leitura</span>
        </header>

        <div class="signature-thesis-copy">
          <h2 id="signature-thesis-title">A presença digital precisa tornar evidente aquilo que a empresa já sustenta na prática.</h2>
          <p>
            Muitos negócios qualificados chegam ao digital com uma contradição: entregam bem, atendem bem, cobram de acordo com um padrão superior, mas aparecem como qualquer outro concorrente. O site não sustenta confiança, a linguagem não revela critério e os sinais públicos não ajudam clientes, Google ou sistemas de IA a entenderem por que aquela empresa merece atenção.
          </p>
        </div>

        <aside class="signature-thesis-card" aria-label="Como o M-Signature resolve essa lacuna">
          <span>M-Signature</span>
          <p>
            O M-Signature resolve essa lacuna por implementação. A marca é lida como operação, cultura, atendimento, oferta, reputação e experiência. Depois, essa leitura se transforma em linguagem, estrutura técnica, site, dados organizados e presença local mais coerente.
          </p>
        </aside>
      </div>
    </section>

    <section class="signature-clarity" data-nav-surface="light" aria-labelledby="signature-clarity-title">
      <div class="signature-shell signature-statement-layout">
        <header class="signature-section-head">
          <p class="signature-kicker signature-kicker-dark">O que você contrata</p>
          <span>02 / Clareza</span>
        </header>

        <h2 id="signature-clarity-title">Uma implementação para tornar o valor real da empresa mais legível.</h2>

        <div class="signature-clarity-modules" aria-label="Resumo da intervenção M-Signature">
          {clarityModules.map((item) => (
            <article>
              <span>{item.label}</span>
              <p>{item.copy}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="signature-scope" data-nav-surface="dark" aria-labelledby="signature-scope-title">
      <div class="signature-shell signature-scope-head">
        <p class="signature-kicker">Escopo integrado</p>
        <h2 id="signature-scope-title"><span class="signature-dropcap" aria-hidden="true">Q</span><span>uatro frentes trabalhando para a mesma percepção.</span></h2>
      </div>

      <div class="signature-shell signature-scope-list">
        {scopeItems.map((item, index) => (
          <article>
            <span>{String(index + 1).padStart(2, '0')}</span>
            <h3>{item.title}</h3>
            <p>{item.copy}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="signature-fit" data-nav-surface="light" aria-labelledby="signature-fit-title">
      <div class="signature-shell signature-fit-grid">
        <div class="signature-fit-title">
          <p class="signature-kicker signature-kicker-dark">Aderência</p>
          <h2 id="signature-fit-title">Para quem o M-Signature foi desenhado.</h2>
        </div>

        <div class="signature-fit-columns">
          <section aria-labelledby="fit-good-title">
            <h3 id="fit-good-title">Faz sentido quando</h3>
            <ul>
              {fitItems.map((item) => <li><span aria-hidden="true">—</span>{item}</li>)}
            </ul>
          </section>

          <section aria-labelledby="fit-bad-title">
            <h3 id="fit-bad-title">Não é o caminho para</h3>
            <ul>
              {nonFitItems.map((item) => <li><span aria-hidden="true">—</span>{item}</li>)}
            </ul>
          </section>
        </div>
      </div>
    </section>

    <section class="signature-proof" data-nav-surface="dark" aria-labelledby="signature-proof-title">
      <div class="signature-shell signature-proof-grid">
        <div class="signature-proof-copy">
          <p class="signature-kicker">Atuação</p>
          <h2 id="signature-proof-title">Setores em que clareza, reputação e confiança pesam antes do contato.</h2>
          <p>
            A aplicação do método se concentra nos setores em que a percepção antecipa a decisão: operações nas quais o cliente precisa reconhecer critério, segurança, repertório ou confiança antes do primeiro contato. A lista é curada por esse princípio, sem disponibilidade genérica de atendimento.
          </p>
        </div>

        <div class="signature-sector-list" aria-label="Setores atendidos">
          {signatureSectors.map((sector) => (
            <details>
              <summary>
                <span>{sector.name}</span>
              </summary>
              <div>
                <p>{sector.description}</p>
                <a href={`/setores/${sector.slug}/`}>Ver abordagem para {sector.name.toLowerCase()}</a>
              </div>
            </details>
          ))}
        </div>
      </div>
    </section>

    <section class="signature-process" data-nav-surface="light" aria-labelledby="signature-process-title">
      <div class="signature-shell signature-process-layout">
        <header class="signature-section-head">
          <p class="signature-kicker signature-kicker-dark">Processo</p>
          <span>90 dias</span>
        </header>

        <h2 id="signature-process-title">O projeto tem começo, profundidade e entrega definida.</h2>

        <div class="signature-process-list">
          {processSteps.map((step) => (
            <article>
              <span>{step.label}</span>
              <div>
                <h3>{step.title}</h3>
                <p>
                  {step.copy}
                  {step.link && <a href={step.link.href}>{step.link.label}</a>}
                  {step.suffix}
                </p>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="signature-tech" data-nav-surface="dark" aria-labelledby="signature-tech-title">
      <div class="signature-shell signature-tech-grid">
        <header class="signature-section-head signature-tech-head">
          <p class="signature-kicker">Base técnica</p>
          <span>07 / Técnica</span>
        </header>

        <div class="signature-tech-table" aria-label="Camadas técnicas do M-Signature">
          {technicalLayers.map(([label, copy]) => (
            <div>
              <span>{label}</span>
              <p>{copy}</p>
            </div>
          ))}
        </div>

        <div class="signature-tech-copy">
          <h2 id="signature-tech-title">A infraestrutura existe para tornar a substância mais legível.</h2>
          <p>
            A construção técnica privilegia performance, segurança, estrutura semântica, dados organizados e experiência de leitura. O propósito é estabelecer uma comunicação limpa, compreensível e confiável para pessoas, motores de busca e sistemas generativos.
          </p>
        </div>
      </div>
    </section>

    <section class="signature-decision" data-nav-surface="light" aria-labelledby="signature-decision-title">
      <div class="signature-shell signature-decision-grid">
        <div>
          <p class="signature-kicker signature-kicker-dark">Decisão</p>
          <h2 id="signature-decision-title">A candidatura existe para entender se o projeto precisa deste nível de profundidade.</h2>
        </div>

        <div class="signature-decision-copy">
          <p>
            O investimento é definido depois do diagnóstico porque o escopo real não pode ser calculado antes da leitura do negócio. A candidatura também protege o processo: nem todo negócio precisa desse nível de personalização, e nem todo momento justifica uma implementação completa.
          </p>
          <ol class="signature-decision-steps" aria-label="Próximos passos da candidatura">
            <li>Você envia a candidatura.</li>
            <li>O contexto é avaliado.</li>
            <li>O diagnóstico define escopo e investimento.</li>
          </ol>
          <a class="moura-button moura-button-dark" href="/candidatura">Iniciar candidatura</a>
        </div>
      </div>
    </section>
  </main>

  <SiteFooter />
</BaseLayout>

<script>
  const sectorDetails = document.querySelectorAll<HTMLDetailsElement>('.signature-sector-list details');

  sectorDetails.forEach((detail) => {
    detail.addEventListener('toggle', () => {
      if (!detail.open) return;

      sectorDetails.forEach((item) => {
        if (item !== detail) item.open = false;
      });
    });
  });
</script>

<style>
  .signature-page {
    overflow: hidden;
    background: var(--moura-paper);
    color: var(--moura-ink);
  }

  .signature-shell {
    width: min(100% - clamp(2rem, 7vw, 8rem), 88rem);
    margin-inline: auto;
  }

  .signature-kicker,
  .signature-section-head span,
  .signature-hero-system,
  .signature-scope-list span,
  .signature-process-list > article > span {
    margin: 0;
    font-family: "Neue Haas Display", "Outfit", sans-serif;
    font-size: 0.74rem;
    font-weight: 300;
    line-height: 1.1;
    letter-spacing: 0;
    text-transform: uppercase;
  }

  .signature-kicker {
    color: rgba(244, 239, 231, 0.78);
  }

  .signature-kicker-dark {
    color: #6f4c1f;
  }

  .signature-hero,
  .signature-scope,
  .signature-proof,
  .signature-tech {
    background: #060606;
    color: var(--moura-ivory);
  }

  .signature-hero {
    position: relative;
    display: grid;
    min-height: 100vh;
    align-items: center;
    padding-block: 8rem 6rem;
    background: linear-gradient(180deg, #050505 0%, #0d0d0c 100%);
  }

  .signature-hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 0.9fr) minmax(21rem, 0.55fr);
    gap: clamp(3rem, 8vw, 8rem);
    align-items: end;
  }

  .signature-hero-copy {
    display: grid;
    gap: 1.35rem;
  }

  .signature-hero h1,
  .signature-statement-layout h2,
  .signature-scope-head h2,
  .signature-fit-title h2,
  .signature-proof h2,
  .signature-process-layout h2,
  .signature-tech h2,
  .signature-decision h2 {
    margin: 0;
    font-family: "Outfit", "Avenir Next", sans-serif;
    font-weight: 100;
    letter-spacing: 0;
  }

  .signature-hero h1 {
    max-width: 12.5ch;
    font-size: clamp(3.6rem, 7.2vw, 8.9rem);
    line-height: 0.9;
    color: rgba(244, 239, 231, 0.94);
  }

  .signature-hero-aside {
    display: grid;
    justify-items: start;
    gap: 1.5rem;
    max-width: 35rem;
    border-top: 1px solid rgba(244, 239, 231, 0.12);
    padding-top: 1.4rem;
  }

  .signature-hero-aside p,
  .signature-scope-list p,
  .signature-proof-copy p,
  .signature-tech-copy p {
    margin: 0;
    font-family: "Neue Haas Display", "Outfit", sans-serif;
    font-size: clamp(1rem, 1.16vw, 1.16rem);
    font-weight: 300;
    line-height: 1.68;
    color: rgba(244, 239, 231, 0.78);
  }

  .signature-page :global(.moura-button) {
    width: 15.5rem;
    max-width: 100%;
  }

  .signature-hero-system {
    position: absolute;
    right: clamp(2rem, 7vw, 8rem);
    bottom: clamp(2rem, 4vw, 4rem);
    left: clamp(2rem, 7vw, 8rem);
    display: grid;
    grid-template-columns: minmax(14rem, 0.7fr) repeat(3, minmax(9rem, 1fr));
    gap: clamp(1.2rem, 3vw, 3rem);
    align-items: center;
    border-top: 1px solid rgba(244, 239, 231, 0.1);
    padding-top: 1rem;
    color: rgba(244, 239, 231, 0.78);
  }

  .signature-hero-system p {
    margin: 0;
    color: #c79a55;
  }

  .signature-hero-system span {
    text-align: right;
  }

  .signature-thesis,
  .signature-clarity,
  .signature-fit,
  .signature-process,
  .signature-decision {
    padding-block: clamp(7rem, 11vw, 11rem);
    background: var(--moura-paper);
  }

  .signature-thesis {
    min-height: 100vh;
    min-height: 100dvh;
    display: grid;
    align-items: center;
    overflow: hidden;
    padding-block: clamp(4rem, 6vw, 5.5rem);
  }

  .signature-thesis-layout {
    position: relative;
    display: grid;
    grid-template-columns: repeat(12, minmax(0, 1fr));
    gap: clamp(2rem, 5vw, 5rem);
    align-items: end;
  }

  .signature-thesis-layout::before {
    content: "";
    position: absolute;
    inset: -8vh -8vw;
    background:
      radial-gradient(circle at 14% 18%, rgba(167, 124, 61, 0.1), transparent 30%),
      linear-gradient(90deg, rgba(8, 8, 8, 0.026) 1px, transparent 1px) 0 0 / calc(100% / 12) 100%;
    opacity: 0.78;
    pointer-events: none;
  }

  .signature-thesis-layout > * {
    position: relative;
    z-index: 1;
  }

  .signature-thesis-head {
    grid-column: 1 / -1;
    margin-bottom: clamp(1.5rem, 3vw, 2.75rem);
  }

  .signature-thesis-copy {
    grid-column: 1 / 9;
    display: grid;
    gap: clamp(1.6rem, 3vw, 2.6rem);
  }

  .signature-thesis-copy h2 {
    max-width: 15ch;
    margin: 0;
    color: rgba(8, 8, 8, 0.9);
    font-size: clamp(3.1rem, 6.2vw, 7.4rem);
    font-weight: 300;
    line-height: 0.94;
    letter-spacing: -0.055em;
  }

  .signature-thesis-copy p {
    max-width: 65ch;
    margin: 0;
    border-top: 1px solid rgba(8, 8, 8, 0.16);
    padding-top: clamp(1.25rem, 2.2vw, 1.8rem);
    color: rgba(8, 8, 8, 0.68);
    font-family: "Neue Haas Display", "Outfit", sans-serif;
    font-size: clamp(1.02rem, 1.25vw, 1.22rem);
    font-weight: 300;
    line-height: 1.72;
  }

  .signature-thesis-card {
    grid-column: 9 / -1;
    display: grid;
    gap: clamp(1.2rem, 2vw, 1.8rem);
    align-self: end;
    background:
      linear-gradient(155deg, rgba(244, 239, 231, 0.055), rgba(244, 239, 231, 0.01)),
      #080808;
    border: 1px solid rgba(167, 124, 61, 0.28);
    box-shadow: 0 2rem 5rem rgba(8, 8, 8, 0.18);
    padding: clamp(1.5rem, 3vw, 2.6rem);
    transform: translateY(clamp(1rem, 3vw, 2.5rem));
  }

  .signature-thesis-card span {
    color: #c79a55;
    font-family: "Neue Haas Display", "Outfit", sans-serif;
    font-size: 0.72rem;
    font-weight: 300;
    line-height: 1.1;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  .signature-thesis-card p {
    margin: 0;
    color: rgba(244, 239, 231, 0.78);
    font-family: "Neue Haas Display", "Outfit", sans-serif;
    font-size: clamp(1rem, 1.12vw, 1.12rem);
    font-weight: 300;
    line-height: 1.7;
  }

  .signature-statement-layout,
  .signature-process-layout {
    position: relative;
    display: grid;
    grid-template-columns: repeat(12, minmax(0, 1fr));
    row-gap: clamp(2.2rem, 4vw, 4rem);
  }

  .signature-statement-layout::before,
  .signature-process-layout::before {
    content: "";
    position: absolute;
    inset: 0;
    background: repeating-linear-gradient(90deg, rgba(8, 8, 8, 0.032) 0 1px, transparent 1px calc(100% / 12));
    pointer-events: none;
  }

  .signature-statement-layout::before {
    opacity: 0.22;
  }

  .signature-process-layout::before {
    opacity: 0.46;
  }

  .signature-statement-layout > *,
  .signature-process-layout > * {
    position: relative;
    z-index: 1;
  }

  .signature-section-head {
    grid-column: 1 / -1;
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 2rem;
    align-items: center;
  }

  .signature-section-head span {
    color: #6f4c1f;
  }

  .signature-tech .signature-section-head span {
    color: #c79a55;
  }

  .signature-statement-layout h2,
  .signature-process-layout h2 {
    grid-column: 1 / 9;
    max-width: 16ch;
    font-size: clamp(2.8rem, 5.2vw, 6.4rem);
    line-height: 0.96;
    color: rgba(8, 8, 8, 0.9);
  }

  .signature-statement-copy {
    grid-column: 8 / -1;
    display: grid;
    gap: 1.45rem;
    max-width: 72ch;
    border-top: 1px solid rgba(8, 8, 8, 0.16);
    padding-top: clamp(1.4rem, 3vw, 2.2rem);
  }

  .signature-statement-copy p,
  .signature-clarity-modules p,
  .signature-fit li,
  .signature-process-list p,
  .signature-decision-copy p,
  .signature-decision-steps li {
    margin: 0;
    font-family: "Neue Haas Display", "Outfit", sans-serif;
    font-size: clamp(1rem, 1.12vw, 1.14rem);
    font-weight: 300;
    line-height: 1.7;
    color: rgba(8, 8, 8, 0.68);
