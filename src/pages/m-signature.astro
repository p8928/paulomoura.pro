  .signature-scope-head .signature-kicker {
    grid-column: 1 / -1;
  }

  .signature-scope-head h2,
  .signature-proof h2,
  .signature-tech h2 {
    max-width: 15ch;
    font-size: clamp(2.8rem, 5.3vw, 6.2rem);
    line-height: 0.96;
    color: rgba(244, 239, 231, 0.92);
  }

  .signature-scope-head h2 {
    grid-column: 1 / -1;
    display: grid;
    grid-template-columns: clamp(7rem, 14vw, 14rem) minmax(0, 14ch);
    column-gap: clamp(1rem, 2.4vw, 2.5rem);
    align-items: start;
    max-width: none;
  }

  .signature-scope-head h2 .signature-dropcap {
    position: relative;
    display: block;
    width: fit-content;
    color: #c79a55;
    font-family: "Outfit", "Avenir Next", sans-serif;
    font-size: clamp(10rem, 20vw, 20rem);
    font-weight: 100;
    line-height: 0.92;
    padding-bottom: 0.08em;
    transform: translateY(-0.08em);
    text-shadow: 0 0 42px rgba(167, 124, 61, 0.08);
  }


  .signature-scope-head h2 span:not(.signature-dropcap) {
    display: block;
  }

  .signature-scope-list {
    display: grid;
    grid-template-columns: repeat(12, minmax(0, 1fr));
    border-top: 1px solid rgba(244, 239, 231, 0.18);
  }

  .signature-scope-list article {
    grid-column: 1 / -1;
    display: grid;
    grid-template-columns: subgrid;
    align-items: start;
    border-bottom: 1px solid rgba(244, 239, 231, 0.18);
    padding-block: clamp(1.65rem, 2.8vw, 2.35rem);
  }

  .signature-scope-list article > span {
    grid-column: 1 / 2;
  }

  .signature-scope-list article > h3 {
    grid-column: 3 / 6;
  }

  .signature-scope-list article > p {
    grid-column: 7 / -1;
  }

  .signature-scope-list span {
    color: #c79a55;
  }

  .signature-process-list > article > span {
    color: #6f4c1f;
  }

  .signature-scope-list h3,
  .signature-process-list h3,
  .signature-fit h3 {
    margin: 0;
    font-family: "Neue Haas Display", "Outfit", sans-serif;
    font-size: clamp(1.35rem, 2vw, 2.25rem);
    font-weight: 300;
    line-height: 1.08;
  }

  .signature-scope-list h3 {
    color: rgba(244, 239, 231, 0.88);
  }

  .signature-scope-list p {
    max-width: 70ch;
  }

  .signature-fit-grid,
  .signature-proof-grid,
  .signature-tech-grid,
  .signature-decision-grid {
    display: grid;
    grid-template-columns: repeat(12, minmax(0, 1fr));
    gap: clamp(2rem, 5vw, 5rem);
    align-items: start;
  }

  .signature-fit-title {
    grid-column: 1 / 6;
    display: grid;
    gap: 1.25rem;
  }

  .signature-fit-title h2,
  .signature-decision h2 {
    max-width: 13ch;
    font-size: clamp(2.8rem, 5.1vw, 6rem);
    line-height: 0.96;
    color: rgba(8, 8, 8, 0.9);
  }

  .signature-fit-columns {
    grid-column: 7 / -1;
    display: grid;
    gap: clamp(2rem, 4vw, 3.5rem);
  }

  .signature-fit-columns section {
    border-top: 1px solid rgba(8, 8, 8, 0.16);
    padding-top: 1.4rem;
