  .signature-fit h3 {
    color: rgba(8, 8, 8, 0.84);
  }

  .signature-fit ul {
    display: grid;
    gap: 0.8rem;
    margin: 1.2rem 0 0;
    padding: 0;
    list-style: none;
  }

  .signature-fit li {
    display: grid;
    grid-template-columns: 1.5rem 1fr;
    gap: 0.8rem;
    align-items: start;
  }

  .signature-fit li span {
    display: block;
    color: #6f4c1f;
    font-family: "Neue Haas Display", "Outfit", sans-serif;
    font-size: 1rem;
    line-height: 1.65;
  }

  .signature-proof-copy {
    grid-column: 1 / 8;
    display: grid;
    gap: 1rem;
    align-content: start;
  }

  .signature-proof-copy .signature-kicker {
    font-size: 0.68rem;
    letter-spacing: 0.16em;
  }

  .signature-proof-copy p:last-child {
    max-width: 42rem;
  }

  .signature-sector-list {
    grid-column: 8 / -1;
    display: grid;
    align-self: end;
    border-top: 1px solid rgba(244, 239, 231, 0.18);
  }

  .signature-sector-list details {
    border-bottom: 1px solid rgba(244, 239, 231, 0.18);
  }

  .signature-sector-list summary {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    cursor: pointer;
    list-style: none;
    padding-block: 1rem;
  }

  .signature-sector-list summary::-webkit-details-marker {
    display: none;
  }

  .signature-sector-list summary::after {
    content: "+";
    color: #c79a55;
    font-family: "Neue Haas Display", "Outfit", sans-serif;
    font-size: 1rem;
    font-weight: 300;
    line-height: 1;
  }

  .signature-sector-list details[open] summary::after {
    content: "-";
  }

  .signature-sector-list summary span {
    display: block;
    font-family: "Neue Haas Display", "Outfit", sans-serif;
    font-size: clamp(1.05rem, 1.5vw, 1.5rem);
    font-weight: 300;
    color: rgba(244, 239, 231, 0.82);
  }

  .signature-sector-list details > div {
    display: grid;
    gap: 0.85rem;
    padding: 0 0 1.1rem;
  }

  .signature-sector-list p {
    max-width: 28rem;
    margin: 0;
    font-family: "Neue Haas Display", "Outfit", sans-serif;
    font-size: clamp(0.86rem, 0.95vw, 0.96rem);
    font-weight: 300;
    line-height: 1.58;
    color: rgba(244, 239, 231, 0.78);
  }

  .signature-sector-list a {
    width: fit-content;
    border: 1px solid rgba(244, 239, 231, 0.18);
    color: rgba(244, 239, 231, 0.78);
    padding: 0.62rem 0.75rem;
    font-family: "Neue Haas Display", "Outfit", sans-serif;
    font-size: 0.68rem;
    font-weight: 300;
    line-height: 1;
    letter-spacing: 0;
    text-decoration: none;
    text-transform: uppercase;
    transition:
      border-color 180ms ease,
      background 180ms ease,
      color 180ms ease;
  }

  .signature-sector-list a:hover,
  .signature-sector-list a:focus-visible {
    border-color: rgba(167, 124, 61, 0.58);
    background: rgba(167, 124, 61, 0.12);
    color: rgba(244, 239, 231, 0.9);
  }

  .signature-process-list {
    grid-column: 1 / -1;
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    border-top: 1px solid rgba(8, 8, 8, 0.16);
    border-left: 1px solid rgba(8, 8, 8, 0.16);
  }

  .signature-process-list article {
    display: grid;
    align-content: start;
    gap: clamp(1.2rem, 2vw, 2rem);
    min-height: 23rem;
    border-right: 1px solid rgba(8, 8, 8, 0.16);
    border-bottom: 1px solid rgba(8, 8, 8, 0.16);
    padding: clamp(1.2rem, 2vw, 1.7rem);
  }

  .signature-process-list div {
    display: grid;
    gap: 0.8rem;
    max-width: 62rem;
  }

  .signature-process-list h3 {
    min-height: 2.25em;
    color: rgba(8, 8, 8, 0.86);
  }

  .signature-process-list a {
    color: #5f3f17;
    font-weight: 400;
    text-decoration-line: underline;
    text-decoration-color: rgba(95, 63, 23, 0.78);
    text-decoration-thickness: 0.08em;
    text-underline-offset: 0.18em;
  }

  .signature-process-list a:hover,
  .signature-process-list a:focus-visible {
    color: #080808;
    text-decoration-color: currentColor;
  }

  .signature-tech-table {
    grid-column: 1 / 7;
    display: grid;
    border-top: 1px solid rgba(244, 239, 231, 0.18);
  }

  .signature-tech-table div {
    display: grid;
    grid-template-columns: minmax(8rem, 0.38fr) minmax(0, 0.62fr);
    gap: clamp(1rem, 2vw, 2rem);
    border-bottom: 1px solid rgba(244, 239, 231, 0.18);
    padding-block: 1rem;
  }

  .signature-tech-table span {
    color: #c79a55;
    font-family: "Neue Haas Display", "Outfit", sans-serif;
    font-size: 0.74rem;
    font-weight: 300;
    line-height: 1.2;
    text-transform: uppercase;
  }

  .signature-tech-table p {
    margin: 0;
    color: rgba(244, 239, 231, 0.78);
    font-family: "Neue Haas Display", "Outfit", sans-serif;
    font-size: 1rem;
    font-weight: 300;
    line-height: 1.55;
  }

  .signature-tech-head {
    grid-column: 1 / -1;
  }

  .signature-tech-copy {
    grid-column: 8 / -1;
    display: grid;
    gap: 1.35rem;
    align-self: center;
  }

  .signature-decision-grid > div:first-child {
    grid-column: 1 / 7;
    display: grid;
    gap: 1.25rem;
  }

  .signature-decision-copy {
    grid-column: 8 / -1;
    display: grid;
    justify-items: start;
    gap: 1.5rem;
    border-top: 1px solid rgba(8, 8, 8, 0.16);
    padding-top: 1.4rem;
  }

  .signature-decision-steps {
    display: grid;
    gap: 0.7rem;
    margin: 0;
    padding: 0;
    list-style: none;
    counter-reset: decision;
  }

  .signature-decision-steps li {
    counter-increment: decision;
    display: grid;
    grid-template-columns: 2.4rem 1fr;
    gap: 0.8rem;
    align-items: baseline;
  }

  .signature-decision-steps li::before {
    content: counter(decision, decimal-leading-zero);
    color: #6f4c1f;
    font-family: "Neue Haas Display", "Outfit", sans-serif;
    font-size: 0.74rem;
    line-height: 1;
  }

