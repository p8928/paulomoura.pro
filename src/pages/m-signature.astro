  .signature-clarity-modules {
    grid-column: 4 / -1;
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    border-top: 1px solid rgba(8, 8, 8, 0.11);
    border-left: 1px solid rgba(8, 8, 8, 0.11);
  }

  .signature-clarity-modules article {
    display: grid;
    align-content: start;
    gap: 1rem;
    min-height: 13rem;
    border-right: 1px solid rgba(8, 8, 8, 0.11);
    border-bottom: 1px solid rgba(8, 8, 8, 0.11);
    padding: clamp(1.2rem, 2vw, 1.7rem);
  }

  .signature-clarity-modules span {
    font-family: "Neue Haas Display", "Outfit", sans-serif;
    font-size: 0.74rem;
    font-weight: 300;
    line-height: 1.1;
    text-transform: uppercase;
    color: #6f4c1f;
  }

  .signature-clarity-modules p {
    color: rgba(8, 8, 8, 0.72);
  }

  .signature-scope,
  .signature-proof,
  .signature-tech {
    padding-block: clamp(7rem, 11vw, 11rem);
  }

  .signature-scope-head {
    position: relative;
    display: grid;
    grid-template-columns: repeat(12, minmax(0, 1fr));
    gap: 1.25rem;
    margin-bottom: clamp(4rem, 7vw, 7rem);
