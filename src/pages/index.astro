---
import HeroNavigation from '@components/navigation/HeroNavigation.svelte';
import HomeHero from '@components/sections/home/HomeHero.astro';
import OffWhiteSection from '@components/sections/home/OffWhiteSection.astro';
import ComprehensionSection from '@components/sections/home/ComprehensionSection.astro';
import MethodStackSection from '@components/sections/home/MethodStackSection.svelte';
import QualifiedPresenceSection from '@components/sections/home/QualifiedPresenceSection.astro';
import { brand } from '@data/brand';
import BaseLayout from '@layouts/BaseLayout.astro';
---

<BaseLayout title="Brand-Driven boutique digital" description={brand.promise} showChrome={false}>
  <script>
    import '@scripts/lenis';
  </script>

  <HeroNavigation client:load />

  <div class="brand-atmosphere">
    <img
      class="brand-atmosphere-image"
      src="/images/editorial/brand-driven-material.webp"
      alt=""
      width="1122"
      height="1402"
      loading="lazy"
      decoding="async"
      aria-hidden="true"
    />
    <div class="relative h-[200vh]">
      <div class="sticky top-0 z-0 h-screen overflow-hidden">
        <OffWhiteSection />
      </div>
      <div class="absolute inset-x-0 top-0 z-20 h-screen overflow-hidden">
        <HomeHero />
      </div>
    </div>

    <ComprehensionSection />
  </div>
  <MethodStackSection client:load />
  <QualifiedPresenceSection />
</BaseLayout>
