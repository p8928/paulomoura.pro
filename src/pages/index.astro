---
import HeroNavigation from '@components/navigation/HeroNavigation.svelte';
import HomeSection01Hero from '@components/sections/home/HomeSection01Hero.astro';
import HomeSection02BrandDriven from '@components/sections/home/HomeSection02BrandDriven.astro';
import HomeSection03ValueCriteria from '@components/sections/home/HomeSection03ValueCriteria.astro';
import HomeSection04MethodStack from '@components/sections/home/HomeSection04MethodStack.svelte';
import HomeSection05QualifiedPresence from '@components/sections/home/HomeSection05QualifiedPresence.astro';
import HomeSection06Signature from '@components/sections/home/HomeSection06Signature.astro';
import HomeSection07Application from '@components/sections/home/HomeSection07Application.svelte';
import { brand } from '@data/brand';
import BaseLayout from '@layouts/BaseLayout.astro';
import SiteFooter from '@components/site/SiteFooter.astro';
---

<BaseLayout title="Brand-Driven boutique digital" description={brand.promise} showChrome={false}>
  <script>
    import '@scripts/lenis';
  </script>

  <HeroNavigation client:load />

  <div class="brand-atmosphere">
    <div class="relative h-[200vh]">
      <div class="sticky top-0 z-0 h-screen overflow-hidden">
        <HomeSection02BrandDriven />
      </div>
      <div class="absolute inset-x-0 top-0 z-20 h-screen overflow-hidden">
        <HomeSection01Hero />
      </div>
    </div>

    <div class="brand-atmosphere-transition" aria-label="Transição entre método e critério">
      <span>02 / 03</span>
      <p>Da tese ao critério</p>
    </div>

    <HomeSection03ValueCriteria />
  </div>
  <HomeSection04MethodStack client:load />
  <HomeSection05QualifiedPresence />
  <div class="final-stack">
    <div class="final-stack-sticky">
      <HomeSection06Signature />
    </div>
    <div class="final-stack-panel">
      <HomeSection07Application client:load />
    </div>
  </div>
  <SiteFooter />
</BaseLayout>
