---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Sidebar from '../components/Sidebar.astro';
import SideDecorations from '../components/SideDecorations.astro';
import Hero from '../components/Hero.astro';
import Testimonials from '../components/Testimonials.astro';
import HyggeBreak from '../components/HyggeBreak.astro';
import SuccessStories from '../components/SuccessStories.astro';
import Journey from '../components/Journey.astro';
import Help from '../components/Help.astro';
import Faq from '../components/Faq.astro';
import Contact from '../components/Contact.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Tiago Gomes - Advogado Trabalhista">
 
  <Header />
  <Sidebar />
  <SideDecorations />

  <main class="w-full bg-brand-background text-brand-text">
    <Hero />
    <Testimonials />
    <HyggeBreak />
    <SuccessStories />
    <Journey />
    <Help />
    <Faq />
    <Contact />
  </main>

  <Footer />
</Layout>
