---
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <!-- Hamburger Button -->
  <button id="hamburger-button" aria-label="Abrir menu" class="fixed top-4 right-4 sm:top-8 sm:right-8 p-2 text-brand-text z-50">
    <svg id="menu-icon" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16m-7 6h7" />
    </svg>
    <svg id="close-icon" class="h-6 w-6 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
    </svg>
  </button>

  <!-- Sidebar Menu -->
  <aside id="sidebar-menu" class="fixed top-0 right-0 h-full w-full md:w-72 bg-[#F3F0E9]/80 md:backdrop-blur-md z-40 transform translate-x-full transition-transform duration-500 ease-in-out shadow-[0_8px_30px_rgb(0,0,0,0.12)] md:shadow-none flex items-center justify-center">
    <nav class="p-8">
      <ul class="space-y-4 text-center">
        <li><a href="#sobre" class="font-outfit font-light tracking-widest uppercase text-sm text-brand-text hover:text-brand-primary relative after:content-[''] after:absolute after:w-0 after:h-px after:bg-brand-primary after:bottom-0 after:left-1/2 after:-translate-x-1/2 after:transition-all after:duration-300 hover:after:w-full">Sobre</a></li>
        <li><a href="#sucesso" class="font-outfit font-light tracking-widest uppercase text-sm text-brand-text hover:text-brand-primary relative after:content-[''] after:absolute after:w-0 after:h-px after:bg-brand-primary after:bottom-0 after:left-1/2 after:-translate-x-1/2 after:transition-all after:duration-300 hover:after:w-full">Histórias de Sucesso</a></li>
        <li><a href="#ajuda" class="font-outfit font-light tracking-widest uppercase text-sm text-brand-text hover:text-brand-primary relative after:content-[''] after:absolute after:w-0 after:h-px after:bg-brand-primary after:bottom-0 after:left-1/2 after:-translate-x-1/2 after:transition-all after:duration-300 hover:after:w-full">Como podemos ajudar</a></li>
        <li><a href="#" class="font-outfit font-light tracking-widest uppercase text-sm text-brand-text hover:text-brand-primary relative after:content-[''] after:absolute after:w-0 after:h-px after:bg-brand-primary after:bottom-0 after:left-1/2 after:-translate-x-1/2 after:transition-all after:duration-300 hover:after:w-full">Blog</a></li>
        <li><a href="#contato" class="font-outfit font-light tracking-widest uppercase text-sm text-brand-text hover:text-brand-primary relative after:content-[''] after:absolute after:w-0 after:h-px after:bg-brand-primary after:bottom-0 after:left-1/2 after:-translate-x-1/2 after:transition-all after:duration-300 hover:after:w-full">Contato</a></li>
        <li class="pt-4">
          <button class="bg-[#725752] text-white font-outfit font-light tracking-widest text-sm py-2 px-4 rounded transition-all duration-300 ease-in-out hover:bg-brand-primary hover:shadow-lg uppercase">Tire suas dúvidas</button>
        </li>
      </ul>
    </nav>
  </aside>

  <!-- Overlay -->
  <div id="overlay" class="fixed inset-0 z-30 hidden bg-black/20"></div>

  <div 
    class="w-full bg-brand-background text-brand-text"
    style="
      background-color: #F3F0E9;
      background-image: 
        /* Layer 3: Gaps - The Golden Mean */
        repeating-linear-gradient(0deg, transparent, transparent 100px, rgba(234, 227, 217, 0.4) 101px, transparent 102px, transparent 200px),
        /* Layer 2: Chaos - The Golden Mean */
        repeating-linear-gradient(87deg, transparent, transparent 28px, rgba(234, 227, 217, 0.3) 29px, rgba(249, 245, 236, 0.3) 30px, transparent 31px, transparent 55px),
        /* Layer 1: Base - The Golden Mean */
        repeating-linear-gradient(88deg, transparent, transparent 18px, #EDE8DE 19px, #F7F4EE 20px, transparent 21px);
    "
  >
    <!-- Header -->
    <header class="fixed top-0 left-0 right-0 z-20 p-4 sm:p-8">
      <div class="flex justify-between items-center">
        <a href="/" class="flex items-center space-x-3">
          <img src="/images/tg-logo.png" alt="Tiago Gomes Logo" class="h-10 sm:h-12">
        </a>
        <div id="header-line" class="flex-grow h-px bg-gradient-to-r from-transparent via-brand-primary to-transparent mx-4 sm:mx-8 line-shimmer transition-opacity duration-300"></div>
      </div>
    </header>

    <!-- Text Vertical (Left) -->
    <aside class="hidden md:block fixed -left-6 top-1/2 -translate-y-1/2 transform -rotate-90 z-10">
      <span class="font-sans text-xs tracking-widest text-brand-primary font-[100]">ADVOGADO TRABALHISTA</span>
    </aside>

    <!-- Social Icons (Left) -->
    <aside class="hidden md:flex fixed left-16 bottom-8 flex-col space-y-6 z-10">
      <a href="#" aria-label="Visite nosso Facebook" class="text-brand-text hover:text-brand-primary transition-transform duration-300 ease-in-out hover:-translate-y-1">
        <img src="/images/facebook.png" alt="Facebook" class="w-4 h-4">
      </a>
      <a href="#" aria-label="Visite nosso Instagram" class="text-brand-text hover:text-brand-primary transition-transform duration-300 ease-in-out hover:-translate-y-1">
        <img src="/images/instagram.png" alt="Instagram" class="w-4 h-4">
      </a>
      <a href="#" aria-label="Visite nosso LinkedIn" class="text-brand-text hover:text-brand-primary transition-transform duration-300 ease-in-out hover:-translate-y-1">
        <img src="/images/linkedin.png" alt="LinkedIn" class="w-4 h-4">
      </a>
    </aside>

    <!-- Hero Section -->
    <section class="h-screen flex flex-col justify-center items-center p-4 sm:p-8 pt-32 sm:pt-36">
      <main id="hero-text" class="text-center">
        <h1 class="font-serif text-5xl sm:text-6xl lg:text-8xl" style="line-height: 1.5 !important;">
          SEUS DIREITOS,
          <br>
          <span class="font-outfit italic font-[100] text-holographic inline-block">NOSSA</span> LUTA.
        </h1>
        <a href="#" class="btn-hygge-gold mt-12 sm:mt-16">
          ME CHAME NO WHATSAPP
        </a>
      </main>
    </section>

    <!-- Section 2: Seriedade e Respeito -->
    <section class="py-24 sm:py-32 px-4 sm:px-8">
      <div class="max-w-4xl mx-auto text-center">
        <h2 class="font-serif text-4xl sm:text-5xl lg:text-6xl" style="line-height: 1.5 !important;">
          A seriedade que você espera, com o respeito que merece.
        </h2>
        <div class="w-48 h-px bg-brand-text mx-auto my-12"></div>
        <form action="https://formspree.io/f/YOUR_UNIQUE_FORM_ID" method="POST">
          <p class="text-sm sm:text-base leading-loose font-light max-w-lg mx-auto">
            Tratamos seu caso com profissionalismo, ética e respeito, oferecendo toda a transparência a fim de que você compreenda cada etapa nos mínimos detalhes.
          </p>
        </form>
        <div class="mt-20 max-w-3xl mx-auto relative">
          <!-- Testimonial Slider -->
          <div class="swiper testimonial-swiper px-10">
            <div class="swiper-wrapper">
              <!-- Slide 1 -->
              <div class="swiper-slide">
                <div class="text-center px-8">
                  <div class="flex justify-center text-gold-gradient mb-4 text-2xl">★★★★★</div>
                  <p class="text-sm sm:text-base font-light max-w-md mx-auto">"Tiago é super atencioso, prestativo, e muito esclarecedor em seu atendimento. Com certeza, recomendo."</p>
                  <p class="mt-3 font-bold text-sm">Juliana Santos</p>
                  <a href="#" class="inline-flex items-center mt-2 text-xs text-gray-500 hover:text-brand-primary transition-colors duration-300">
                    <img src="/images/google_g_icon.png" alt="Google Icon" class="w-3 h-3 mr-2">
                    Verificar no Google
                  </a>
                </div>
              </div>
              <!-- Slide 2 -->
              <div class="swiper-slide">
                <div class="text-center px-8">
                  <div class="flex justify-center text-gold-gradient mb-4 text-2xl">★★★★★</div>
                  <p class="text-sm sm:text-base font-light max-w-md mx-auto">"Fui bem atendida e estou sendo bem atendida, meus parabéns e continuem sempre assim."</p>
                  <p class="mt-3 font-bold text-sm">Ana Lucia</p>
                  <a href="#" class="inline-flex items-center mt-2 text-xs text-gray-500 hover:text-brand-primary transition-colors duration-300">
                    <img src="/images/google_g_icon.png" alt="Google Icon" class="w-3 h-3 mr-2">
                    Verificar no Google
                  </a>
                </div>
              </div>
              <!-- Slide 4 -->
              <div class="swiper-slide">
                <div class="text-center px-8">
                  <div class="flex justify-center text-gold-gradient mb-4 text-2xl">★★★★★</div>
                  <p class="text-sm sm:text-base font-light max-w-md mx-auto">"Super recomendo muito atencioso."</p>
                  <p class="mt-3 font-bold text-sm">Priscilla Mariana</p>
                  <a href="#" class="inline-flex items-center mt-2 text-xs text-gray-500 hover:text-brand-primary transition-colors duration-300">
                    <img src="/images/google_g_icon.png" alt="Google Icon" class="w-3 h-3 mr-2">
                    Verificar no Google
                  </a>
                </div>
              </div>
              <!-- Slide 5 -->
              <div class="swiper-slide">
                <div class="text-center px-8">
                  <div class="flex justify-center text-gold-gradient mb-4 text-2xl">★★★★★</div>
                  <p class="text-sm sm:text-base font-light max-w-md mx-auto">"Excelente profissional!"</p>
                  <p class="mt-3 font-bold text-sm">Jessica Basilio</p>
                  <a href="#" class="inline-flex items-center mt-2 text-xs text-gray-500 hover:text-brand-primary transition-colors duration-300">
                    <img src="/images/google_g_icon.png" alt="Google Icon" class="w-3 h-3 mr-2">
                    Verificar no Google
                  </a>
                </div>
              </div>
            </div>
            <!-- Navigation buttons -->
            <div class="swiper-button-prev text-brand-primary left-0 transition-transform duration-300 ease-in-out hover:scale-110 hover:drop-shadow-lg"></div>
            <div class="swiper-button-next text-brand-primary right-0 transition-transform duration-300 ease-in-out hover:scale-110 hover:drop-shadow-lg"></div>
          </div>
        </div>
      </div>
    </section>

    <!-- Hygge Scales of Justice Break -->
    <section class="py-24 sm:py-32 px-4 sm:px-8 text-center">
      <!-- Invitation Text -->
      <p class="hygge-text font-serif italic text-4xl text-[#725752] mb-20">
        Vamos tomar um café e pensar na melhor solução para você?
      </p>

      <!-- Scales Animation -->
      <div class="flex items-center justify-center max-w-2xl mx-auto">
        <!-- Left Pan -->
        <div class="w-3 h-3 rounded-full pulsing-pan"></div>
        <!-- Beam -->
        <div class="flex-grow h-px bg-brand-primary/30 mx-4"></div>
        <!-- Fulcrum -->
        <div class="w-3 h-3 rotate-45 bg-brand-primary/50"></div>
        <!-- Beam -->
        <div class="flex-grow h-px bg-brand-primary/30 mx-4"></div>
        <!-- Right Pan -->
        <div class="w-3 h-3 rounded-full pulsing-pan pan-right"></div>
      </div>

      <!-- CTA -->
      <div class="mt-20">
        <a href="#contato" class="inline-flex justify-center items-center space-x-4 group">
          <div class="calendar-icon transition-all duration-300 ease-in-out group-hover:scale-110 group-hover:shadow-lg"></div>
          <p class="relative text-lg font-serif italic text-[#725752] transition-colors duration-300 ease-in-out group-hover:text-brand-primary after:absolute after:bottom-[-2px] after:left-1/2 after:h-px after:w-0 after:-translate-x-1/2 after:bg-[#725752] after:transition-all after:duration-300 group-hover:after:w-full group-hover:after:bg-brand-primary">Diga qual o melhor dia para conversarmos</p>
        </a>
      </div>
    </section>

    <!-- Section 3: Atendimento Ágil -->
    <section id="sobre" class="py-24 sm:py-32 px-4 sm:px-8">
      <div class="max-w-4xl mx-auto text-center">
        <h2 class="font-serif text-4xl sm:text-5xl lg:text-6xl" style="line-height: 1.5 !important;">Atendimento ágil e descomplicado</h2>
        <p class="text-sm sm:text-base leading-loose font-light mt-8 max-w-2xl mx-auto">Em até três etapas, explicamos suas possibilidades de forma clara. Funciona assim:</p>
        <div class="mt-16 grid md:grid-cols-3 gap-x-8 lg:gap-x-12 group text-left">
          <!-- Step 1 -->
          <div class="relative p-8 transition-all duration-300 ease-in-out group-hover:opacity-50 hover:!opacity-100 hover:scale-105">
            <span class="absolute top-0 left-0 font-serif text-8xl text-brand-primary -z-10 opacity-0 group-hover:opacity-10 transition-opacity duration-500">01</span>
            <h3 class="font-outfit text-xl mb-2">Explique a situação</h3>
            <p class="font-outfit text-sm font-light">Ouviremos sua história e suas reivindicações.</p>
          </div>
          <!-- Step 2 -->
          <div class="relative p-8 transition-all duration-300 ease-in-out group-hover:opacity-50 hover:!opacity-100 hover:scale-105">
            <span class="absolute top-0 left-0 font-serif text-8xl text-brand-primary -z-10 opacity-0 group-hover:opacity-10 transition-opacity duration-500">02</span>
            <h3 class="font-outfit text-xl mb-2">Análise do caso</h3>
            <p class="font-outfit text-sm font-light">Analisaremos os fatos para verificar seus direitos.</p>
          </div>
          <!-- Step 3 -->
          <div class="relative p-8 transition-all duration-300 ease-in-out group-hover:opacity-50 hover:!opacity-100 hover:scale-105">
            <span class="absolute top-0 left-0 font-serif text-8xl text-brand-primary -z-10 opacity-0 group-hover:opacity-10 transition-opacity duration-500">03</span>
            <h3 class="font-outfit text-xl mb-2">Próximas Etapas</h3>
            <p class="font-outfit text-sm font-light">Planejaremos as ações para prosseguir com o processo.</p>
          </div>
        </div>
        <div class="mt-16">
          <a href="#contato" class="btn-hygge">
            DÊ O PRIMEIRO PASSO
          </a>
        </div>
      </div>
    </section>


    <!-- Section 4: Como podemos te ajudar -->
    <section id="ajuda" class="pt-24 pb-16 sm:pt-32 sm:pb-2 px-4 sm:px-8 bg-opacity-50" style="background-color: rgba(237, 232, 222, 0.5);">
      <div class="max-w-4xl mx-auto text-center">
        <h2 class="font-serif text-4xl sm:text-5xl lg:text-6xl" style="line-height: 1.5 !important;">Como podemos te ajudar juridicamente?</h2>
        <p class="text-sm sm:text-base leading-loose font-light mt-8 max-w-2xl mx-auto">Você está passando por algumas das situações, abaixo? Mande sua mensagem pelo WhatsApp ou no formulário para cuidarmos do seu caso com agilidade.</p>
      </div>
      <div class="mt-16 max-w-4xl mx-auto grid md:grid-cols-2 gap-8 lg:gap-12" x-data="{ active: 1 }">
        <!-- Left Column: List of Specialties -->
        <div class="flex flex-col justify-center space-y-2">
          <div role="button" tabindex="0" @click="active = 1" @keydown.enter.space="active = 1" :class="{'active-stationery': active === 1}" class="text-left p-4 rounded-lg transition-all duration-300 ease-in-out cursor-pointer">
            <h3 class="font-outfit text-base">Acidente de trabalho</h3>
          </div>
          <div role="button" tabindex="0" @click="active = 2" @keydown.enter.space="active = 2" :class="{'active-stationery': active === 2}" class="text-left p-4 rounded-lg transition-all duration-300 ease-in-out cursor-pointer">
            <h3 class="font-outfit text-base">Doenças ocupacionais</h3>
          </div>
          <div role="button" tabindex="0" @click="active = 3" @keydown.enter.space="active = 3" :class="{'active-stationery': active === 3}" class="text-left p-4 rounded-lg transition-all duration-300 ease-in-out cursor-pointer">
            <h3 class="font-outfit text-base">Situação de assédio</h3>
          </div>
          <div role="button" tabindex="0" @click="active = 4" @keydown.enter.space="active = 4" :class="{'active-stationery': active === 4}" class="text-left p-4 rounded-lg transition-all duration-300 ease-in-out cursor-pointer">
            <h3 class="font-outfit text-base">Horas extras não pagas</h3>
          </div>
          <div role="button" tabindex="0" @click="active = 5" @keydown.enter.space="active = 5" :class="{'active-stationery': active === 5}" class="text-left p-4 rounded-lg transition-all duration-300 ease-in-out cursor-pointer">
            <h3 class="font-outfit text-base">Desvio ou acúmulo de função</h3>
          </div>
          <div role="button" tabindex="0" @click="active = 6" @keydown.enter.space="active = 6" :class="{'active-stationery': active === 6}" class="text-left p-4 rounded-lg transition-all duration-300 ease-in-out cursor-pointer">
            <h3 class="font-outfit text-base">Insalubridade e Periculosidade</h3>
          </div>
        </div>
        <!-- Right Column: Descriptions and Icons -->
        <div class="animated-gradient-border rounded-lg" style="padding: 1px;">
          <div class="inner-box min-h-[20rem] p-8 lg:p-12 flex flex-col justify-center items-center text-center rounded-lg h-full w-full" style="background: linear-gradient(to bottom, #FFFFFF, #F9F9F9);">
            <div x-show="active === 1" x-transition:enter="transition ease-out duration-300" x-transition:enter-start="opacity-0 transform scale-95" x-transition:enter-end="opacity-100 transform scale-100">
              <div class="w-24 h-24 mx-auto mb-4 relative flex items-center justify-center">
                <svg class="w-20 h-20 text-brand-primary/80" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="0.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" />
                </svg>
              </div>
              <p class="font-light">Cuidamos de todo o processo para garantir que você receba o suporte e a compensação que merece após um acidente.</p>
            </div>
            <div x-show="active === 2" x-transition:enter="transition ease-out duration-300" x-transition:enter-start="opacity-0 transform scale-95" x-transition:enter-end="opacity-100 transform scale-100">
              <div class="w-24 h-24 mx-auto mb-4 relative flex items-center justify-center">
                <!-- Heart Outline -->
                <svg class="w-full h-full text-brand-primary/60" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="0.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M4.318 6.318a4.5 4.5 0 016.364 0L12 7.636l1.318-1.318a4.5 4.5 0 116.364 6.364L12 20.364l-7.682-7.682a4.5 4.5 0 010-6.364z" />
                </svg>
                <!-- EKG Line -->
                <svg class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-16 h-16 text-brand-primary/80" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="0.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M4 12h4l2 4 4-8 2 4h4" />
                </svg>
              </div>
              <p class="font-light">Se sua saúde foi afetada pelo trabalho, lutamos para que seus direitos e bem-estar sejam plenamente reconhecidos.</p>
            </div>
            <div x-show="active === 3" x-transition:enter="transition ease-out duration-300" x-transition:enter-start="opacity-0 transform scale-95" x-transition:enter-end="opacity-100 transform scale-100">
              <div class="w-24 h-24 mx-auto mb-4 relative flex flex-col items-center justify-end">
                <div class="w-8 h-8 rounded-full border-2 border-brand-primary/60"></div>
                <div class="w-12 h-6 border-t-2 border-l-2 border-r-2 border-brand-primary/60 rounded-t-full mt-2"></div>
              </div>
              <p class="font-light">Oferecemos um ambiente seguro e o suporte jurídico necessário para combater o assédio e restaurar sua dignidade.</p>
            </div>
            <div x-show="active === 4" x-transition:enter="transition ease-out duration-300" x-transition:enter-start="opacity-0 transform scale-95" x-transition:enter-end="opacity-100 transform scale-100">
              <div class="w-24 h-24 mx-auto mb-4 relative flex items-center justify-center">
                <svg class="w-20 h-20 text-brand-primary/80" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="0.5">
                  <!-- Clock face -->
                  <circle cx="12" cy="12" r="9" />
                  <!-- Clock hands -->
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 7v5l3 3" />
                </svg>
              </div>
              <p class="font-light">Garantimos que seu trabalho extra seja devidamente recompensado, lutando por cada hora não paga.</p>
            </div>
            <div x-show="active === 5" x-transition:enter="transition ease-out duration-300" x-transition:enter-start="opacity-0 transform scale-95" x-transition:enter-end="opacity-100 transform scale-100">
              <div class="w-24 h-24 mx-auto mb-4 relative flex items-center justify-center">
                <div class="w-12 h-12 border-[0.5px] border-brand-primary/50 absolute top-2 left-2"></div>
                <div class="w-12 h-12 border-[0.5px] border-brand-primary/70 absolute bottom-2 right-2"></div>
              </div>
              <p class="font-light">Se você está fazendo mais do que foi contratado, buscamos o reconhecimento e a compensação justa por suas responsabilidades.</p>
            </div>
            <div x-show="active === 6" x-transition:enter="transition ease-out duration-300" x-transition:enter-start="opacity-0 transform scale-95" x-transition:enter-end="opacity-100 transform scale-100">
              <div class="w-24 h-24 mx-auto mb-4 relative flex items-center justify-center">
                <svg class="w-20 h-20 text-brand-primary/80" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="0.5">
                  <!-- Head Outline -->
                  <path stroke-linecap="round" stroke-linejoin="round" d="M7 3h10a4 4 0 014 4v10a4 4 0 01-4 4H7a4 4 0 01-4-4V7a4 4 0 014-4z" />
                  <!-- Eyes -->
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 9h-2l-1 3h4l-1-3z" />
                  <path stroke-linecap="round" stroke-linejoin="round" d="M17 9h-2l-1 3h4l-1-3z" />
                  <!-- Respirator -->
                  <circle cx="12" cy="17" r="3" />
                  <circle cx="12" cy="17" r="1" />
                  <!-- Side Filters -->
                  <path stroke-linecap="round" stroke-linejoin="round" d="M4 15h-1.5a.5.5 0 00-.5.5v3a.5.5 0 00.5.5h1.5" />
                  <path stroke-linecap="round" stroke-linejoin="round" d="M20 15h1.5a.5.5 0 01.5.5v3a.5.5 0 01-.5.5h-1.5" />
                </svg>
              </div>
              <p class="font-light">Lutamos para que os riscos que você corre sejam devidamente compensados com os adicionais de direito.</p>
            </div>
          </div>
        </div>
      </div>
      <div class="mt-24 text-center">
        <a href="#contato" class="btn-hygge">CONHEÇA SEUS DIREITOS</a>
      </div>

    <!-- Section 5: Contato -->
    <section id="contato" class="py-24 sm:py-32 px-4 sm:px-8 bg-opacity-50" style="background-color: rgba(237, 232, 222, 0.5);">
      <div class="max-w-4xl mx-auto text-center">
        <h2 class="font-serif text-4xl sm:text-5xl lg:text-6xl" style="line-height: 1.5 !important;">
          Prefere mandar um email? 
        </h2>
        <p class="font-sanz text-sm sm:text-base leading-loose font-light mt-12">
          Preencha o formulário abaixo e teremos o maior prazer em responder o mais breve possível.
        </p>
        <form action="https://formspree.io/f/YOUR_UNIQUE_ID" method="POST" class="mt-16 max-w-xl mx-auto text-left space-y-6">
          <div>
            <label for="name" class="block text-sm font-montserrat-light mb-2">Nome</label>
            <input type="text" id="name" name="name" class="w-full p-3 bg-transparent border border-brand-primary/30 rounded-md focus:ring-1 focus:ring-brand-primary focus:outline-none">
          </div>
          <div>
            <label for="email" class="block text-sm font-montserrat-light mb-2">Email</label>
            <input type="email" id="email" name="email" class="w-full p-3 bg-transparent border border-brand-primary/30 rounded-md focus:ring-1 focus:ring-brand-primary focus:outline-none">
          </div>
          <div>
            <label for="message" class="block text-sm font-montserrat-light mb-2">Mensagem</label>
            <textarea id="message" name="message" rows="5" class="w-full p-3 bg-transparent border border-brand-primary/30 rounded-md focus:ring-1 focus:ring-brand-primary focus:outline-none"></textarea>
          </div>
          <div class="text-center">
            <button type="submit" class="btn-hygge">
              ENVIAR
            </button>
          </div>
        </form>
      </div>
    </section>

    <!-- Footer -->
    <footer class="w-full py-8 px-4 sm:px-8">
      <div class="flex flex-col items-stretch">
        <div class="flex items-center">
          <div class="flex-grow h-px bg-gradient-to-r from-transparent via-brand-primary to-transparent line-shimmer"></div>
          <p class="text-xs font-light pl-4 text-brand-primary flex-shrink-0">&copy; 2025 Tiago Gomes</p>
        </div>
        <div class="flex justify-end mt-4">
          <p class="text-xs font-light">
            Desenvolvido por <a href="#" class="hover:text-brand-primary transition-colors duration-300">Paulo Moura</a>
          </p>
        </div>
      </div>
    </footer>
  </div>
</Layout>

  <style>
  .swiper-slide {
    -webkit-user-select: none; /* Safari */
    -moz-user-select: none;    /* Firefox */
    -ms-user-select: none;     /* IE10+/Edge */
    user-select: none;         /* Standard */
  }

  @keyframes animated-gradient {
    0% {
      background-position: 0% 50%;
    }
    50% {
      background-position: 100% 50%;
    }
    100% {
      background-position: 0% 50%;
    }
  }

  .animated-gradient-border {
    background: linear-gradient(60deg, #D4AF37, #FFD700, #B8860B, #FFD700, #D4AF37);
    background-size: 400% 400%;
    animation: animated-gradient 5s ease infinite;
  }

  .active-stationery {
    background-color: #F3F0E9; /* Cor de papel */
    background-image: radial-gradient(rgba(212, 175, 55, 0.15) 1px, transparent 1px);
    background-size: 5px 5px;
    box-shadow: 
      /* Borda interna sutil para definir a forma */
      inset 0 0 0 1px rgba(0, 0, 0, 0.05),
      /* Sombra interna para dar profundidade e textura */
      inset 0 3px 8px 0 rgba(0, 0, 0, 0.1);
    transform: scale(1.05);
  }

  .hygge-button {
    display: inline-block;
    padding: 0.75rem 1.5rem;
    border-radius: 0.25rem;
    color: white;
    font-family: 'Outfit', sans-serif;
    font-weight: 300;
    font-size: 0.875rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    cursor: pointer;
    text-align: center;
    text-decoration: none;
    transition: background-color 0.3s ease-in-out, box-shadow 0.3s ease-in-out;
    background: 
      linear-gradient(45deg, rgba(255, 255, 255, 0.04) 25%, transparent 25%, transparent 75%, rgba(255, 255, 255, 0.04) 75%, rgba(255, 255, 255, 0.04)),
      linear-gradient(-45deg, rgba(255, 255, 255, 0.04) 25%, transparent 25%, transparent 75%, rgba(255, 255, 255, 0.04) 75%, rgba(255, 255, 255, 0.04))
      #725752;
    background-size: 8px 8px;
  }

  .hygge-button:hover {
    background: 
      linear-gradient(45deg, rgba(255, 255, 255, 0.04) 25%, transparent 25%, transparent 75%, rgba(255, 255, 255, 0.04) 75%, rgba(255, 255, 255, 0.04)),
      linear-gradient(-45deg, rgba(255, 255, 255, 0.04) 25%, transparent 25%, transparent 75%, rgba(255, 255, 255, 0.04) 75%, rgba(255, 255, 255, 0.04))
      #a39a8e; /* Cor de hover com a textura */
    background-size: 8px 8px;
    box-shadow: 0 4px 15px rgba(0,0,0,0.2);
  }
</style>
</style>

<script>
  // Sidebar Menu Script
  document.addEventListener('DOMContentLoaded', () => {
    const hamburgerButton = document.getElementById('hamburger-button');
    const sidebarMenu = document.getElementById('sidebar-menu');
    const overlay = document.getElementById('overlay');
    const menuIcon = document.getElementById('menu-icon');
    const closeIcon = document.getElementById('close-icon');
    const menuLinks = document.querySelectorAll('#sidebar-menu a');

    if (!hamburgerButton || !sidebarMenu || !overlay || !menuIcon || !closeIcon) return;

    const toggleMenu = () => {
      const isOpen = !sidebarMenu.classList.contains('translate-x-full');
      sidebarMenu.classList.toggle('translate-x-full', isOpen);
      overlay.classList.toggle('hidden', isOpen);
      
      // Explicitly manage icon visibility
      if (isOpen) {
        menuIcon.classList.remove('hidden');
        closeIcon.classList.add('hidden');
      } else {
        menuIcon.classList.add('hidden');
        closeIcon.classList.remove('hidden');
      }
    };

    hamburgerButton.addEventListener('click', toggleMenu);
    overlay.addEventListener('click', toggleMenu);

    menuLinks.forEach(link => {
      link.addEventListener('click', (e) => {
        e.preventDefault();
        const href = link.getAttribute('href');
        toggleMenu();
        
        setTimeout(() => {
          if (href) {
            const targetElement = document.querySelector(href);
            if (targetElement) {
              targetElement.scrollIntoView({ behavior: 'smooth' });
            }
          }
        }, 500);
      });
    });
  });

  // Header line fade effect
  document.addEventListener('DOMContentLoaded', () => {
    const headerLine = document.getElementById('header-line');
    const heroText = document.getElementById('hero-text');
    
    if (headerLine && heroText) {
      document.addEventListener('scroll', () => {
        const scrollPosition = window.scrollY;
        const fadeEnd = heroText.offsetTop - 4;
        let opacity = 1;
        if (scrollPosition > 0 && scrollPosition < fadeEnd) {
          opacity = 1 - (scrollPosition / fadeEnd);
        } else if (scrollPosition >= fadeEnd) {
          opacity = 0;
        }
        headerLine.style.opacity = Math.max(0, Math.min(1, opacity)).toString();
      });
    }
  });

  // Testimonial Slider Initialization
  document.addEventListener('DOMContentLoaded', () => {
    const swiper = new Swiper('.testimonial-swiper', {
      loop: true,
      autoplay: {
        delay: 5000,
        disableOnInteraction: false,
      },
      navigation: {
        nextEl: '.swiper-button-next',
        prevEl: '.swiper-button-prev',
      },
    });
  });
</script>
</Layout>

