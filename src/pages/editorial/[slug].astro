---
import { getCollection, render } from 'astro:content';
import ArticleLayout from '@layouts/ArticleLayout.astro';

const categoryLabels = {
  branding: 'Marca',
  seo: 'SEO',
  geo: 'GEO',
  aeo: 'AEO',
  luxury: 'Luxury',
  estrategia: 'Estratégia',
};

export async function getStaticPaths() {
  const posts = await getCollection('editorial');

  return posts
    .filter((post) => !post.data.draft)
    .map((post) => ({
      params: { slug: post.id },
      props: { post },
    }));
}

const { post } = Astro.props;
const { Content, headings } = await render(post);

const words = (post.body ?? "").trim().split(/\s+/).filter(Boolean).length;
const readingTime = `${Math.max(1, Math.ceil(words / 220))} min de leitura`;
const tableOfContents = headings
  .filter((heading) => heading.depth === 2)
  .map((heading) => ({
    depth: heading.depth,
    slug: heading.slug,
    text: heading.text,
  }));

const posts = (await getCollection('editorial'))
  .filter((entry) => !entry.data.draft && entry.id !== post.id)
  .sort((a, b) => {
    const categoryWeight = Number(b.data.category === post.data.category) - Number(a.data.category === post.data.category);

    if (categoryWeight !== 0) {
      return categoryWeight;
    }

    return b.data.publishedAt.getTime() - a.data.publishedAt.getTime();
  })
  .slice(0, 3)
  .map((entry) => ({
    href: `/editorial/${entry.id}/`,
    title: entry.data.title,
    description: entry.data.description,
    category: categoryLabels[entry.data.category],
  }));
---

<ArticleLayout
  title={post.data.title}
  description={post.data.description}
  metaDescription={post.data.metaDescription}
  seoTitle={post.data.seoTitle}
  keywords={post.data.keywords}
  canonicalPath={post.data.canonicalPath}
  category={categoryLabels[post.data.category]}
  publishedAt={post.data.publishedAt}
  updatedAt={post.data.updatedAt}
  readingTime={readingTime}
  tableOfContents={tableOfContents}
  recommendations={posts}
>
  <Content />
</ArticleLayout>
