---
import SiteFooter from '@components/site/SiteFooter.astro';
import SiteHeader from '@components/site/SiteHeader.astro';
import CookieConsent from '@components/site/CookieConsent.astro';
import { brand } from '@data/brand';
import { createBaseSchemaGraph } from '@data/schema';
import '@styles/global.css';

interface Props {
  title?: string;
  description?: string;
  keywords?: string[];
  canonicalPath?: string;
  ogType?: 'website' | 'article';
  structuredData?: Record<string, unknown> | Record<string, unknown>[];
  schemaPageType?: string | string[];
  schemaMainEntity?: Record<string, unknown>;
  showChrome?: boolean;
}

const {
  title = brand.name + ' | ' + brand.concept,
  description = brand.promise,
  keywords = [],
  canonicalPath,
  ogType = 'website',
  structuredData,
  schemaPageType = 'WebPage',
  schemaMainEntity,
  showChrome = true,
} = Astro.props;

const pageTitle = title.includes(brand.name) ? title : title + ' | ' + brand.name;
const canonicalUrl = new URL(canonicalPath ?? Astro.url.pathname, Astro.site);
const structuredDataNodes = structuredData ? (Array.isArray(structuredData) ? structuredData : [structuredData]) : [];
const schemaGraph = createBaseSchemaGraph({
  canonicalUrl,
  pageTitle,
  description,
  pageType: schemaPageType,
  mainEntity: schemaMainEntity,
  extraNodes: structuredDataNodes,
});
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <meta name="theme-color" content="#f7f4ef" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#080808" media="(prefers-color-scheme: dark)" />
    <meta name="description" content={description} />
    {keywords.length > 0 && <meta name="keywords" content={keywords.join(', ')} />}
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonicalUrl} />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(schemaGraph)} />
  </head>
  <body>
    {showChrome && <SiteHeader />}
    <main>
      <slot />
    </main>
    {showChrome && <SiteFooter />}
    <CookieConsent />
  </body>
</html>
