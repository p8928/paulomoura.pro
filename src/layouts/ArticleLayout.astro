---
import BaseLayout from '@layouts/BaseLayout.astro';

interface Props {
  title: string;
  description: string;
  category: string;
}

const { title, description, category } = Astro.props;
---

<BaseLayout title={title} description={description}>
  <article class="mx-auto max-w-3xl px-5 pb-20 pt-32 lg:px-8">
    <p class="text-sm uppercase tracking-[0.22em] text-wine">{category}</p>
    <h1 class="mt-5 font-serif text-6xl leading-tight">{title}</h1>
    <p class="mt-6 text-lg leading-8 text-muted">{description}</p>
    <div class="mt-12 border-t border-line pt-10 text-lg leading-8 text-ink [&_p+p]:mt-6">
      <slot />
    </div>
  </article>
</BaseLayout>
