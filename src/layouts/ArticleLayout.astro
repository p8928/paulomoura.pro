---
import HeroNavigation from '@components/navigation/HeroNavigation.svelte';
import SiteFooter from '@components/site/SiteFooter.astro';
import BaseLayout from '@layouts/BaseLayout.astro';
import { breadcrumbSchema, schemaIdentity } from '@data/schema';

interface Recommendation {
  href: string;
  title: string;
  description: string;
  category: string;
}

interface TableOfContentsItem {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  title: string;
  description: string;
  metaDescription?: string;
  seoTitle?: string;
  keywords?: string[];
  canonicalPath?: string;
  category: string;
  publishedAt: Date;
  updatedAt?: Date;
  readingTime: string;
  readingMinutes?: number;
  wordCount?: number;
  schemaType?: 'Article' | 'BlogPosting';
  schemaAbout?: string[];
  schemaMentions?: string[];
  tableOfContents?: TableOfContentsItem[];
  recommendations?: Recommendation[];
}

const {
  title,
  description,
  metaDescription,
  seoTitle,
  keywords = [],
  canonicalPath,
  category,
  publishedAt,
  updatedAt,
  readingTime,
  readingMinutes,
  wordCount,
  schemaType = 'Article',
  schemaAbout = [],
  schemaMentions = [],
  tableOfContents = [],
  recommendations = [],
} = Astro.props;

const pageDescription = metaDescription || description;
const articleUrl = new URL(canonicalPath ?? Astro.url.pathname, Astro.site);
const schemaTerms = (terms: string[]) => terms.map((name) => ({ '@type': 'DefinedTerm', name }));
const compactSchemaNode = (node: Record<string, unknown>) => Object.fromEntries(
  Object.entries(node).filter(([, value]) => {
    if (value === undefined || value === null) return false;
    if (Array.isArray(value) && value.length === 0) return false;
    return true;
  }),
);
const articleSchema = compactSchemaNode({
  '@type': schemaType,
  '@id': articleUrl.toString() + '#article',
  url: articleUrl.toString(),
  name: title,
  headline: title,
  description: pageDescription,
  abstract: description,
  datePublished: publishedAt.toISOString(),
  dateModified: (updatedAt ?? publishedAt).toISOString(),
  author: { '@id': schemaIdentity.personId },
  publisher: { '@id': schemaIdentity.organizationId },
  mainEntityOfPage: { '@id': articleUrl.toString() + '#webpage' },
  isPartOf: { '@id': schemaIdentity.websiteId },
  inLanguage: 'pt-BR',
  articleSection: category,
  keywords,
  genre: 'Ensaio editorial',
  isAccessibleForFree: true,
  wordCount,
  timeRequired: readingMinutes ? 'PT' + readingMinutes + 'M' : undefined,
  about: schemaAbout.length > 0 ? schemaTerms(schemaAbout) : undefined,
  mentions: schemaMentions.length > 0 ? schemaTerms(schemaMentions) : undefined,
});

const articleBreadcrumbSchema = breadcrumbSchema({
  id: articleUrl.toString() + '#breadcrumb',
  items: [
    { name: 'Início', url: schemaIdentity.baseUrl + '/' },
    { name: 'Editorial', url: schemaIdentity.baseUrl + '/editorial/' },
    { name: title, url: articleUrl.toString() },
  ],
});

const formatDate = (date: Date) =>
  new Intl.DateTimeFormat('pt-BR', {
    day: '2-digit',
    month: 'long',
    year: 'numeric',
  }).format(date);
---

<BaseLayout
  title={seoTitle || title}
  description={pageDescription}
  keywords={keywords}
  canonicalPath={canonicalPath}
  ogType="article"
  structuredData={[articleSchema, articleBreadcrumbSchema]}
  schemaPageType="WebPage"
  schemaMainEntity={{ '@id': articleUrl.toString() + '#article' }}
  showChrome={false}
>
  <script>
    import '@scripts/lenis';
  </script>

  <HeroNavigation client:load />

  <div class="article-progress" aria-hidden="true">
    <span data-article-progress></span>
  </div>

  <article class="article-page">
    <header class="article-hero" data-nav-surface="dark">
      <div class="article-shell">
        <nav class="article-breadcrumbs" aria-label="Breadcrumb">
          <a href="/">Início</a>
          <span aria-hidden="true">/</span>
          <a href="/editorial/">Editorial</a>
          <span aria-hidden="true">/</span>
          <span aria-current="page">{title}</span>
        </nav>
      </div>

      <div class="article-shell article-hero-grid">
        <div>
          <p class="article-kicker">{category}</p>
          <h1>{title}</h1>
        </div>

        <aside class="article-hero-aside" aria-label="Resumo do artigo">
          <p>{description}</p>
        </aside>
      </div>

      <div class="article-shell article-hero-footer" aria-label="Informações do artigo">
        <a class="article-hero-author" href="/autor/paulo-moura/">Paulo Moura</a>
        <span>{category}</span>
        <time datetime={publishedAt.toISOString()}>{formatDate(publishedAt)}</time>
        <span>{readingTime}</span>
        {updatedAt && <span>Atualizado em {formatDate(updatedAt)}</span>}
        <button class="article-copy-link article-copy-link--hero" type="button" data-copy-article-link>Compartilhar</button>
      </div>
    </header>

    <section class="article-body-section" data-nav-surface="light">
      <div class="article-shell article-body-grid">
        <aside class="article-reading-rail" aria-label="Sumário do artigo">
          {tableOfContents.length > 0 && (
            <nav class="article-toc" aria-label="Sumário do artigo">
              <p>Sumário</p>
              {tableOfContents.map((item) => (
                <a href={"#" + item.slug}>{item.text}</a>
              ))}
            </nav>
          )}
        </aside>

        <div class="article-mobile-utils">
          {tableOfContents.length > 0 && (
            <details class="article-mobile-toc">
              <summary>Sumário</summary>
              <nav aria-label="Sumário do artigo no mobile">
                {tableOfContents.map((item) => (
                  <a href={"#" + item.slug}>{item.text}</a>
                ))}
              </nav>
            </details>
          )}
        </div>

        <div class="article-content">
          <slot />
        </div>
      </div>
    </section>

    <section class="article-editorial-notes" data-nav-surface="light" aria-labelledby="article-editorial-notes-title">
      <div class="article-shell article-editorial-notes-grid">
        <div class="article-editorial-notes-head">
          <p>Notas editoriais</p>
          <h2 id="article-editorial-notes-title">Para situar a leitura.</h2>
        </div>

        <div class="article-editorial-notes-list">
          <article>
            <span>01 / Tese</span>
            <p>{description}</p>
          </article>

          <article>
            <span>02 / Percurso</span>
            <p>
              {tableOfContents.length > 0
                ? `O texto se organiza em ${tableOfContents.length} movimentos principais, permitindo avançar pela estrutura sem perder a linha argumentativa.`
                : 'Texto breve, pensado para leitura contínua e sem interrupções de navegação.'}
            </p>
          </article>

          <article>
            <span>03 / Arquivo</span>
            <p>Publicado na frente {category}, com {readingTime}, como parte do arquivo editorial sobre marca, linguagem, busca e presença digital.</p>
          </article>
        </div>
      </div>
    </section>

    {recommendations.length > 0 && (
      <section class="article-recommendations" data-nav-surface="light" aria-labelledby="article-recommendations-title">
        <div class="article-shell article-recommendations-grid">
          <div class="article-recommendations-head">
            <p>Leituras recomendadas</p>
            <h2 id="article-recommendations-title">Continue por textos que ampliam a mesma leitura.</h2>
          </div>

          <div class="article-recommendations-list">
            {recommendations.map((item, index) => (
              <article class="article-recommendation-card">
                <a href={item.href} aria-label={`Ler ${item.title}`}>
                  <span>{String(index + 1).padStart(2, '0')} / {item.category}</span>
                  <h3>{item.title}</h3>
                  <p>{item.description}</p>
                  <strong aria-hidden="true">→</strong>
                </a>
              </article>
            ))}
          </div>
        </div>
      </section>
    )}
  </article>

  <SiteFooter />
  <script>
    const copyButtons = document.querySelectorAll<HTMLButtonElement>("[data-copy-article-link]");

    const progressBar = document.querySelector<HTMLElement>('[data-article-progress]');
    let progressTicking = false;

    const updateProgress = () => {
      if (!progressBar) {
        return;
      }

      const scrollable = document.documentElement.scrollHeight - window.innerHeight;
      const progress = scrollable > 0 ? window.scrollY / scrollable : 0;
      progressBar.style.transform = `scaleX(${Math.min(1, Math.max(0, progress))})`;
      progressTicking = false;
    };

    window.addEventListener('scroll', () => {
      if (!progressTicking) {
        window.requestAnimationFrame(updateProgress);
        progressTicking = true;
      }
    }, { passive: true });

    updateProgress();

    copyButtons.forEach((button) => {
      button.addEventListener("click", async () => {
        try {
          await navigator.clipboard.writeText(window.location.href);
          button.textContent = "Link copiado";
          window.setTimeout(() => {
            button.textContent = button.classList.contains("article-copy-link--hero") ? "Compartilhar" : "Copiar link";
          }, 1800);
        } catch {
          button.textContent = "Copie pela barra";
        }
      });
    });
  </script>
</BaseLayout>

<style>
  .article-progress {
    position: fixed;
    top: 0;
    right: 0;
    left: 0;
    z-index: 80;
    height: 3px;
    background: rgba(8, 8, 8, 0.22);
    pointer-events: none;
  }

  .article-progress span {
    display: block;
    width: 100%;
    height: 100%;
    transform: scaleX(0);
    transform-origin: left center;
    background: linear-gradient(90deg, rgba(167, 124, 61, 0.88), rgba(167, 124, 61, 0.96));
    box-shadow: 0 0 18px rgba(167, 124, 61, 0.28);
    transition: transform 120ms linear;
  }

  .article-page {
    overflow: hidden;
    background: var(--moura-paper);
    color: var(--moura-ink);
  }

  .article-shell {
    width: min(100% - 2rem, 1180px);
    margin: 0 auto;
  }

  .article-hero {
    position: relative;
    min-height: 100vh;
    min-height: 100dvh;
    display: grid;
    align-items: end;
    padding: 9rem 0 clamp(7rem, 12vw, 10rem);
    background:
      radial-gradient(circle at 16% 20%, rgba(167, 124, 61, 0.13), transparent 32%),
      radial-gradient(circle at 82% 76%, rgba(167, 124, 61, 0.2), transparent 34%),
      linear-gradient(135deg, #060606 0%, #111 50%, #070707 100%);
    color: var(--moura-ivory);
  }

  .article-breadcrumbs {
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem;
    max-width: 760px;
    margin-bottom: clamp(2.4rem, 5vw, 4.5rem);
    color: rgba(244, 239, 231, 0.72);
    font-family: "JetBrains Mono", "SFMono-Regular", "Consolas", monospace;
    font-size: 0.66rem;
    font-weight: 400;
    letter-spacing: 0.17em;
    line-height: 1.5;
    text-transform: uppercase;
  }

  .article-breadcrumbs a {
    display: inline-flex;
    align-items: center;
    min-width: 44px;
    min-height: 44px;
    color: rgba(244, 239, 231, 0.72);
    transition: color 240ms ease;
  }

  .article-breadcrumbs a:hover {
    color: var(--moura-gold);
  }

  .article-breadcrumbs span[aria-current="page"] {
    max-width: 42ch;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  @media (min-width: 641px) {
    .article-breadcrumbs > span {
      display: inline-flex;
      align-items: center;
      min-height: 44px;
    }

    .article-breadcrumbs span[aria-current="page"] {
      max-width: min(58vw, 82ch);
    }
  }

  .article-hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.35fr) minmax(280px, 0.55fr);
    gap: clamp(2rem, 7vw, 7rem);
    align-items: end;
  }

  .article-kicker {
    margin: 0;
    font-family: "JetBrains Mono", "SFMono-Regular", "Consolas", monospace;
    color: var(--moura-gold);
    font-size: 0.72rem;
    font-weight: 500;
    letter-spacing: 0.24em;
    text-transform: uppercase;
  }

  .article-hero h1 {
    max-width: 960px;
    margin: 1.35rem 0 0;
    font-size: clamp(3.2rem, 7.6vw, 8.2rem);
    font-weight: 300;
    line-height: 0.92;
    letter-spacing: -0.07em;
  }

  .article-hero-aside {
    border-left: 1px solid rgba(167, 124, 61, 0.45);
    padding-left: clamp(1.25rem, 2.4vw, 2rem);
  }

  .article-hero-aside p {
    margin: 0;
    color: rgba(244, 239, 231, 0.8);
    font-size: clamp(1.02rem, 1.28vw, 1.2rem);
    font-weight: 300;
    line-height: 1.75;
  }

  .article-hero-footer {
    position: absolute;
    right: max(1rem, calc((100vw - 1180px) / 2));
    bottom: clamp(1.75rem, 4vw, 3.6rem);
    left: max(1rem, calc((100vw - 1180px) / 2));
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr)) auto;
    gap: clamp(0.9rem, 2.4vw, 2rem);
    align-items: center;
    border-top: 1px solid rgba(244, 239, 231, 0.15);
    padding-top: clamp(0.85rem, 1.8vw, 1.35rem);
    color: rgba(244, 239, 231, 0.72);
    font-family: "Neue Haas Display", "Outfit", "Avenir Next", "Segoe UI", sans-serif;
    font-size: clamp(0.58rem, 0.7vw, 0.68rem);
    font-weight: 400;
    letter-spacing: 0.18em;
    line-height: 1.4;
    text-transform: uppercase;
  }

  .article-hero-footer a,
  .article-hero-footer time,
  .article-hero-footer span {
    min-width: 0;
  }

  .article-hero-author {
    display: inline-flex;
    align-items: center;
    min-height: 44px;
    color: rgba(244, 239, 231, 0.82);
    text-decoration: none;
    transition: color 220ms ease;
  }

  .article-hero-author:hover,
  .article-hero-author:focus-visible {
    color: var(--moura-gold);
  }

  .article-body-section {
    padding: clamp(4.5rem, 8vw, 7.5rem) 0 clamp(4.5rem, 8vw, 7rem);
  }

  .article-body-grid {
    display: grid;
    grid-template-columns: minmax(120px, 0.25fr) minmax(0, 760px) minmax(120px, 0.25fr);
    gap: clamp(1.5rem, 4vw, 4rem);
    align-items: start;
  }

  .article-reading-rail {
    position: sticky;
    font-family: "JetBrains Mono", "SFMono-Regular", "Consolas", monospace;
    top: 7rem;
    display: flex;
    flex-direction: column;
    gap: 0.72rem;
    color: var(--moura-muted);
    font-size: 0.68rem;
    font-weight: 500;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  .article-reading-rail p,
  .article-reading-rail span,
  .article-reading-rail a {
    margin: 0;
  }

  .article-reading-rail a {
    color: inherit;
    text-decoration: none;
  }

  .article-reading-rail a:hover,
  .article-reading-rail a:focus-visible {
    color: var(--moura-gold);
  }

  .article-reading-rail p {
    color: var(--moura-gold);
  }

  .article-toc {
    display: flex;
    flex-direction: column;
    gap: 0.7rem;
    margin-top: 0;
    padding-top: 0;
    border-top: 0;
  }

  .article-toc p {
    color: var(--moura-gold);
  }

  .article-toc a {
    color: var(--moura-muted);
    font-size: 0.72rem;
    font-weight: 500;
    letter-spacing: 0.04em;
    line-height: 1.35;
    text-transform: none;
    transition: color 220ms ease;
  }

  .article-toc a:hover {
    color: var(--moura-ink);
  }

  .article-copy-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: fit-content;
    min-height: 44px;
    font-family: "JetBrains Mono", "SFMono-Regular", "Consolas", monospace;
    margin-top: 1.55rem;
    border: 1px solid rgba(167, 124, 61, 0.96);
    border-radius: 0;
    background: transparent;
    color: var(--moura-gold);
    cursor: pointer;
    padding: 0.62rem 0.86rem;
    font-size: 0.62rem;
    font-weight: 500;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    transition:
      border-color 220ms ease,
      color 220ms ease;
  }

  .article-copy-link:hover {
    border-color: rgba(167, 124, 61, 1);
    color: var(--moura-gold);
  }

  .article-copy-link--hero {
    justify-self: end;
    margin: 0;
    border-color: rgba(167, 124, 61, 0.96);
    color: var(--moura-gold);
    font-family: inherit;
    font-size: inherit;
    letter-spacing: inherit;
    padding: 0.58rem 0.78rem;
  }

  .article-copy-link--hero:hover {
    border-color: rgba(167, 124, 61, 0.96);
    color: var(--moura-gold);
  }

  .article-mobile-utils {
    display: none;
  }

  .article-content {
    max-width: 760px;
    font-size: clamp(1.08rem, 1.32vw, 1.24rem);
    font-weight: 300;
    line-height: 1.86;
  }

  .article-content :global(p),
  .article-content :global(li),
  .article-content :global(h2),
  .article-content :global(h3),
  .article-content :global(blockquote) {
    hyphens: none;
    overflow-wrap: normal;
    word-break: normal;
  }

  .article-content :global(a),
  .article-content :global(code) {
    overflow-wrap: anywhere;
  }

  .article-content :global(p) {
    margin: 0;
  }

  .article-content :global(p + p) {
    margin-top: 1.65rem;
  }

  .article-content :global(h2) {
    margin: clamp(3.5rem, 6vw, 5.5rem) 0 1.35rem;
    padding-top: 1.25rem;
    border-top: 1px solid rgba(21, 21, 21, 0.16);
    font-size: clamp(2.1rem, 3.8vw, 4rem);
    font-weight: 300;
    line-height: 1;
    letter-spacing: -0.045em;
  }

  .article-content :global(h3) {
    margin: 3rem 0 1rem;
    color: var(--moura-gold);
    font-size: clamp(1.35rem, 2vw, 2rem);
    font-weight: 500;
    line-height: 1.15;
    letter-spacing: -0.025em;
  }

  .article-content :global(blockquote) {
    margin: clamp(2.5rem, 5vw, 4rem) 0;
    border-left: 1px solid var(--moura-gold);
    padding-left: clamp(1.25rem, 3vw, 2rem);
    color: var(--moura-ink);
    font-size: clamp(1.35rem, 2.4vw, 2.25rem);
    line-height: 1.28;
    letter-spacing: -0.035em;
  }

  .article-content :global(blockquote p) {
    margin: 0;
  }

  .article-content :global(ul),
  .article-content :global(ol) {
    margin: 1.6rem 0 2.15rem;
    padding-left: 1.35rem;
  }

  .article-content :global(ul) {
    list-style: disc;
  }

  .article-content :global(ol) {
    list-style: decimal;
  }

  .article-content :global(li) {
    padding-left: 0.25rem;
  }

  .article-content :global(li::marker) {
    color: var(--moura-gold);
  }

  .article-content :global(li + li) {
    margin-top: 0.75rem;
  }

  .article-content :global(a) {
    color: var(--moura-gold);
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 0.2em;
  }

  .article-content :global(strong) {
    font-weight: 500;
  }

  .article-editorial-notes {
    padding: 0 0 clamp(4.5rem, 8vw, 7rem);
    background: var(--moura-paper);
  }

  .article-editorial-notes-grid {
    display: grid;
    grid-template-columns: minmax(180px, 0.35fr) 1fr;
    gap: clamp(2rem, 5vw, 5rem);
    border-top: 1px solid rgba(21, 21, 21, 0.16);
    padding-top: clamp(2rem, 4.5vw, 4rem);
  }

  .article-editorial-notes-head p {
    margin: 0;
    font-family: "JetBrains Mono", "SFMono-Regular", "Consolas", monospace;
    color: var(--moura-gold);
    font-size: 0.72rem;
    font-weight: 500;
    letter-spacing: 0.2em;
    text-transform: uppercase;
  }

  .article-editorial-notes-head h2 {
    max-width: 320px;
    margin: 1rem 0 0;
    font-size: clamp(1.9rem, 3.2vw, 3.25rem);
    font-weight: 300;
    line-height: 1;
    letter-spacing: -0.045em;
  }

  .article-editorial-notes-list {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1px;
    background: rgba(21, 21, 21, 0.14);
  }

  .article-editorial-notes-list article {
    min-height: 15rem;
    background:
      linear-gradient(180deg, rgba(255, 253, 248, 0.72), rgba(247, 244, 239, 0.98)),
      var(--moura-paper);
    padding: clamp(1.25rem, 2.5vw, 2rem);
  }

  .article-editorial-notes-list span {
    color: var(--moura-gold);
    font-family: "JetBrains Mono", "SFMono-Regular", "Consolas", monospace;
    font-size: 0.66rem;
    font-weight: 500;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  .article-editorial-notes-list p {
    margin: 1.25rem 0 0;
    color: var(--moura-muted);
    font-size: clamp(0.98rem, 1.18vw, 1.08rem);
    font-weight: 300;
    line-height: 1.72;
  }

  .article-recommendations {
    padding: 0 0 clamp(6rem, 10vw, 10rem);
    background: var(--moura-paper);
  }

  .article-recommendations-grid {
    display: grid;
    grid-template-columns: minmax(180px, 0.35fr) 1fr;
    gap: clamp(2rem, 5vw, 5rem);
    border-top: 1px solid rgba(21, 21, 21, 0.18);
    padding-top: clamp(2rem, 5vw, 4.5rem);
  }

  .article-recommendations-head p {
    margin: 0;
    font-family: "JetBrains Mono", "SFMono-Regular", "Consolas", monospace;
    color: var(--moura-gold);
    font-size: 0.72rem;
    font-weight: 500;
    letter-spacing: 0.2em;
    text-transform: uppercase;
  }

  .article-recommendations-head h2 {
    max-width: 360px;
    margin: 1rem 0 0;
    font-size: clamp(1.9rem, 3.3vw, 3.4rem);
    font-weight: 300;
    line-height: 1;
    letter-spacing: -0.045em;
  }

  .article-recommendations-list {
    display: grid;
    gap: 0;
  }

  .article-recommendation-card {
    border-bottom: 1px solid rgba(21, 21, 21, 0.14);
  }

  .article-recommendation-card:first-child {
