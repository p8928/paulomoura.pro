---
type LegalSection = {
  title: string;
  body?: string[];
  items?: string[];
};

interface Props {
  kicker: string;
  title: string;
  summary: string;
  updatedAt: string;
  sections: LegalSection[];
}

const { kicker, title, summary, updatedAt, sections } = Astro.props;
---

<main class="legal-page">
  <section class="legal-hero" data-nav-surface="dark" aria-labelledby="legal-title">
    <div class="legal-shell legal-hero-grid">
      <div>
        <p class="legal-kicker">{kicker}</p>
        <h1 id="legal-title">{title}</h1>
      </div>

      <aside>
        <span>Atualizado em {updatedAt}</span>
        <p>{summary}</p>
      </aside>
    </div>

    <aside class="legal-hero-system" aria-label="Coordenadas do documento">
      <p>{kicker}</p>
      <span>{sections.length} seções</span>
      <span>Documento público</span>
      <span>Versão {updatedAt}</span>
    </aside>
  </section>

  <section class="legal-content" data-nav-surface="light">
    <div class="legal-shell legal-layout">
      <nav class="legal-index" aria-label="Seções do documento">
        <p>Índice</p>
        {sections.map((section, index) => (
          <a href={`#secao-${index + 1}`}>{String(index + 1).padStart(2, '0')} / {section.title}</a>
        ))}
      </nav>

      <div class="legal-sections">
        {sections.map((section, index) => (
          <section id={`secao-${index + 1}`}>
            <span>{String(index + 1).padStart(2, '0')}</span>
            <h2>{section.title}</h2>
            {section.body?.map((paragraph) => <p>{paragraph}</p>)}
            {section.items && (
              <ul>
                {section.items.map((item) => <li>{item}</li>)}
              </ul>
            )}
          </section>
        ))}
      </div>
    </div>
  </section>
</main>

<style>
  .legal-page {
    overflow: hidden;
    background: var(--moura-paper);
    color: var(--moura-ink);
  }

  .legal-shell {
    width: min(100% - clamp(2rem, 7vw, 8rem), 82rem);
    margin-inline: auto;
  }

  .legal-kicker,
  .legal-hero aside span,
  .legal-index p,
  .legal-index a,
  .legal-sections section > span {
    margin: 0;
    font-family: "Neue Haas Display", "Outfit", sans-serif;
    font-size: 0.74rem;
    font-weight: 300;
    line-height: 1.1;
    letter-spacing: 0;
    text-transform: uppercase;
  }

  .legal-kicker,
  .legal-hero aside span {
    color: rgba(167, 124, 61, 0.76);
  }

  .legal-hero {
    position: relative;
    display: grid;
    min-height: 100vh;
    align-items: center;
    overflow: hidden;
    padding-block: 8rem 6rem;
    background: linear-gradient(180deg, #050505 0%, #0d0d0c 54%, #060606 100%);
    color: var(--moura-ivory);
  }


  .legal-hero-grid {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: minmax(0, 0.92fr) minmax(20rem, 0.48fr);
    gap: clamp(3rem, 8vw, 8rem);
    align-items: end;
  }

  .legal-hero h1,
  .legal-sections h2 {
    margin: 0;
    font-family: "Outfit", "Avenir Next", sans-serif;
    font-weight: 100;
    letter-spacing: 0;
  }

  .legal-hero h1 {
    max-width: 11.5ch;
    margin-top: 1.1rem;
    color: rgba(244, 239, 231, 0.94);
    font-size: clamp(4rem, 8.4vw, 9.8rem);
    line-height: 0.86;
  }

  .legal-hero aside {
    display: grid;
    gap: 1rem;
    border-top: 1px solid rgba(244, 239, 231, 0.18);
    padding-top: 1.2rem;
  }

  .legal-hero aside p {
    margin: 0;
    color: rgba(244, 239, 231, 0.72);
    font-family: "Neue Haas Display", "Outfit", sans-serif;
    font-size: clamp(1rem, 1.16vw, 1.16rem);
    font-weight: 300;
    line-height: 1.68;
  }

  .legal-hero-system {
    position: absolute;
    right: clamp(2rem, 7vw, 8rem);
    bottom: clamp(2rem, 4vw, 4rem);
    left: clamp(2rem, 7vw, 8rem);
    z-index: 1;
    display: grid;
    grid-template-columns: minmax(14rem, 0.7fr) repeat(3, minmax(9rem, 1fr));
    gap: clamp(1.2rem, 3vw, 3rem);
    align-items: center;
    border-top: 1px solid rgba(244, 239, 231, 0.14);
    padding-top: 1rem;
    color: rgba(244, 239, 231, 0.72);
  }

  .legal-hero-system p,
  .legal-hero-system span {
    margin: 0;
    font-family: "Neue Haas Display", "Outfit", sans-serif;
    font-size: 0.74rem;
    font-weight: 300;
    line-height: 1.1;
    letter-spacing: 0;
    text-transform: uppercase;
  }

  .legal-hero-system p {
    color: rgba(167, 124, 61, 0.76);
  }

  .legal-hero-system span {
    text-align: right;
  }

  .legal-content {
    padding-block: clamp(5rem, 9vw, 8rem);
  }

  .legal-layout {
    display: grid;
    grid-template-columns: minmax(13rem, 0.24fr) minmax(0, 1fr);
    gap: clamp(2rem, 6vw, 6rem);
    align-items: start;
  }

  .legal-index {
    position: sticky;
    top: 7rem;
    display: grid;
    gap: 0.9rem;
    border-top: 1px solid rgba(8, 8, 8, 0.18);
    padding-top: 1rem;
  }

  .legal-index p,
  .legal-sections section > span {
    color: rgba(167, 124, 61, 0.72);
  }

  .legal-index a {
    display: inline-flex;
    align-items: center;
    min-height: 44px;
    color: rgba(8, 8, 8, 0.68);
    text-decoration: none;
  }

  .legal-index a:hover {
    color: rgba(8, 8, 8, 0.9);
  }

  .legal-sections {
    display: grid;
    gap: clamp(2.4rem, 5vw, 4rem);
  }

  .legal-sections section {
    display: grid;
    gap: 1rem;
    border-top: 1px solid rgba(8, 8, 8, 0.16);
    padding-top: clamp(1.2rem, 2vw, 1.8rem);
  }

  .legal-sections h2 {
    max-width: 16ch;
    color: rgba(8, 8, 8, 0.9);
    font-size: clamp(2rem, 3.6vw, 4.4rem);
    line-height: 0.98;
  }

  .legal-sections p,
  .legal-sections li {
    max-width: 76ch;
    margin: 0;
    color: rgba(8, 8, 8, 0.68);
    font-family: "Neue Haas Display", "Outfit", sans-serif;
    font-size: clamp(1rem, 1.08vw, 1.12rem);
    font-weight: 300;
    line-height: 1.72;
  }

  .legal-sections ul {
    display: grid;
    gap: 0.55rem;
    margin: 0;
    padding-left: 1.1rem;
  }

  @media (max-width: 820px) {
    .legal-hero-grid,
    .legal-layout,
    .legal-hero-system {
      grid-template-columns: 1fr;
    }

    .legal-index {
      position: static;
    }

    .legal-hero-system {
      position: static;
      width: min(100% - clamp(2rem, 7vw, 8rem), 82rem);
      margin: clamp(2rem, 6vw, 4rem) auto 0;
    }

    .legal-hero-system span {
      text-align: left;
    }
  }

  @media (max-width: 560px) {
    .legal-shell {
      width: min(100% - 1.5rem, 82rem);
    }

    .legal-hero {
      min-height: 100vh;
      padding-block: 7rem 3rem;
    }

    .legal-hero h1 {
      font-size: clamp(3.25rem, 16vw, 5.2rem);
    }
  }
</style>
