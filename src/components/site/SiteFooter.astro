---
import { brand } from '@data/brand';
---

<footer class="border-t border-line bg-panel">
  <div class="mx-auto grid max-w-7xl gap-8 px-5 py-10 text-sm text-muted lg:grid-cols-[1.3fr_0.7fr] lg:px-8">
    <div>
      <p class="font-serif text-2xl text-ink">{brand.name}</p>
      <p class="mt-3 max-w-2xl">{brand.promise}</p>
    </div>
    <div class="lg:text-right">
      <p>{brand.domain}</p>
      <p class="mt-2">Sao Paulo, Jundiai, Sorocaba e Campinas.</p>
    </div>
  </div>
</footer>
