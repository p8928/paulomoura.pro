---
import { navigation } from '@data/navigation';
---

<header class="fixed inset-x-0 top-0 z-40 border-b border-line/70 bg-panel/88 backdrop-blur-md">
  <div class="mx-auto flex max-w-7xl items-center justify-between px-5 py-4 lg:px-8">
    <a class="font-serif text-2xl tracking-normal" href="/" aria-label="Pagina inicial">
      Paulo Moura
    </a>
    <nav class="hidden items-center gap-6 text-sm text-muted lg:flex" aria-label="Principal">
      {navigation.map((item) => <a class="transition hover:text-ink" href={item.href}>{item.label}</a>)}
    </nav>
    <a class="border border-ink px-4 py-2 text-sm transition hover:bg-ink hover:text-panel" href="/analise">
      Iniciar analise
    </a>
  </div>
</header>
