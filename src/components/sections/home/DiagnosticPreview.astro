---
import DiagnosticConfigurator from '@components/diagnostic/DiagnosticConfigurator.svelte';
---

<section class="mx-auto grid max-w-7xl gap-10 px-5 py-16 lg:grid-cols-[0.85fr_1.15fr] lg:px-8 lg:py-24">
  <div>
    <p class="text-sm uppercase tracking-[0.22em] text-gold">Diagnostico</p>
    <h2 class="mt-4 font-serif text-5xl leading-tight">Experiencia consultiva antes da conversa.</h2>
    <p class="mt-6 text-muted">Este e o primeiro prototipo do configurador. Depois conectamos ferramenta de agenda, WhatsApp e email.</p>
  </div>
  <DiagnosticConfigurator client:load />
</section>
